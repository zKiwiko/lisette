  if sum == 1001000000 { 100 } else { 0 }
}

fn test_both_styles_equal() -> int {
  // Both access styles should yield the same value
  let go_style = time.Second
  let lis_style = time.Duration.Second
  if go_style == lis_style { 100 } else { 0 }
}

fn test_mixed_styles_arithmetic() -> int {
  // Mixing both styles in one expression
  let result = time.Second + time.Duration.Millisecond
  if result == 1001000000 { 100 } else { 0 }
}

fn get_duration_multiplier() -> int {
  3
}

fn test_go_style_times_variable() -> int {
  // Regression: time.Second * n should emit time.Duration(n), not go:time.Duration(n)
  let n = 5
  let d = time.Second * n
  if d == 5000000000 { 100 } else { 0 }
}

fn test_go_style_times_function() -> int {
  // Regression: time.Second * fn() should emit time.Duration(fn()), not go:time.Duration(fn())
  let d = time.Second * get_duration_multiplier()
  if d == 3000000000 { 100 } else { 0 }
}

fn test_lis_style_times_function() -> int {
  // Same for Lisette-style access
  let d = time.Duration.Second * get_duration_multiplier()
  if d == 3000000000 { 100 } else { 0 }
}

// defer tests
// Using integer encoding: acc = acc * 10 + digit to track execution order

fn record(acc: Ref<int>, val: int) {
  acc.* = acc.* * 10 + val
}

fn defer_helper_normal(acc: Ref<int>) {
  defer record(acc, 1)
  record(acc, 2)
}

fn test_defer_cleanup_on_success() -> int {
  // Verify defer runs after normal return: body(2) then defer(1) -> 21
  let mut acc = 0
  defer_helper_normal(&acc)
  if acc == 21 { 100 } else { 0 }
}

fn defer_helper_early_return(acc: Ref<int>) -> Result<int, string> {
  defer record(acc, 1)
  Err("fail")
}

fn test_defer_cleanup_on_early_return() -> int {
  // Verify defer runs on early return: only defer(1) runs -> 1
  let mut acc = 0
  let _ = defer_helper_early_return(&acc)
  if acc == 1 { 100 } else { 0 }
}

fn defer_helper_lifo(acc: Ref<int>) {
  defer record(acc, 1)
  defer record(acc, 2)
  defer record(acc, 3)
}

fn test_defer_lifo_order() -> int {
  // Verify LIFO: defers registered 1,2,3 should run as 3,2,1 -> 321
  let mut acc = 0
  defer_helper_lifo(&acc)
  if acc == 321 { 100 } else { 0 }
}

