  let result = res.map(|x| x * 2)
  match result {
    Ok(v) => v,
    Err(_) => 0,
  }
}

fn test_result_and_then() -> int {
  let res = Ok(10)
  let result = res.and_then(|x| if x > 5 {
    Ok(x * 10)
  } else {
    Err("too small")
  })
  match result {
