package main

import "example.com/shapes"

type Square struct{}

func (s Square) String() string {
	return "Square"
}

func (s Square) Area() (int, error) {
	return 4, nil
}

func (s Square) Name() string {
	return "sq"
}

func describe(s shapes.Shape) string {
	return s.Name()
}

func main() {
	s := Square{}
	_ = describe(s)
}
