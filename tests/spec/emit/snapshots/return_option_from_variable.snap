---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn test(flag: bool) -> Option<int> {\n  let result = if flag { Some(42) } else { None };\n  result\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(flag bool) (int, bool) {
	var v_1 lisette.Option[int]
	if flag {
		v_1 = lisette.MakeOptionSome[int](42)
	} else {
		v_1 = lisette.MakeOptionNone[int]()
	}
	if v_1.Tag == lisette.OptionSome {
		return v_1.SomeVal, true
	}
	return *new(int), false
}
