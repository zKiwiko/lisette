---
source: tests/spec/emit/concurrency.rs
description: "input: \nimport \"go:fmt\"\n\nfn main() {\n  let ch = Channel.buffered<string>(1)\n  ch.send(\"hello\")\n\n  loop {\n    select {\n      let Some(msg) = ch.receive() => {\n        fmt.Println(msg)\n        break\n      },\n      _ => break,\n    }\n  }\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	ch := make(chan string, 1)
	_ = lisette.ChannelSend(ch, "hello")
loop_1:
	for {
		ch_2 := ch
		for {
			select {
			case msg, ok := <-ch_2:
				if ok {
					fmt.Println(msg)
					break loop_1
				}
				ch_2 = nil
				continue
			default:
				break loop_1
			}
			break
		}
	}
}
