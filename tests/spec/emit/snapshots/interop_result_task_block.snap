---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:strconv\"\n\nfn main() {\n  let f = strconv.Atoi\n  task {\n    let r = f(\"42\")\n    let _ = r\n  }\n}\n"
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func main() {
	f := strconv.Atoi
	go func() {
		ret_1, ret_2 := f("42")
		var r lisette.Result[int, error]
		if ret_2 != nil {
			r = lisette.MakeResultErr[int, error](ret_2)
		} else {
			r = lisette.MakeResultOk[int, error](ret_1)
		}
		_ = r
	}()
}
