---
source: tests/spec/emit/concurrency.rs
description: "input: \nstruct P { v: int }\nfn test() {\n  let ch = Channel.buffered<P>(1)\n  ch.send(P { v: 1 })\n  select {\n    let Some(P { v }) = ch.receive() => (),\n    _ => (),\n  }\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

type P struct {
	v int
}

func (p P) String() string {
	return fmt.Sprintf("P { v: %v }", p.v)
}

func test() {
	ch := make(chan P, 1)
	_ = lisette.ChannelSend(ch, P{v: 1})
	ch_1 := ch
	for {
		select {
		case recv_2, ok := <-ch_1:
			if ok {
				_ = recv_2
			} else {
				ch_1 = nil
				continue
			}
		default:
		}
		break
	}
}
