description: "input: \nimport \"go:crypto/sha256\"\n\nfn get() -> fn(Slice<uint8>) -> Slice<uint8> {\n  return sha256.Sum256\n}\n\nfn main() {\n  let f = get()\n  let data: Slice<uint8> = []\n  let out = f(data)\n  let _ = out\n}\n"
---
package main

import "crypto/sha256"

func get() func([]uint8) []uint8 {
	return func(arg0 []byte) []byte {
		arr_1 := sha256.Sum256(arg0)
		return arr_1[:]
	}
}

func main() {
	f := get()
	data := []uint8{}
	_ = f(data)
}
