// match guards

fn test_guard_basic() -> int {
  let opt = Some(42)
  match opt {
    Some(x) if x > 0 => 1,
    Some(_) => 2,
    None => 3,
  }
}

fn test_guard_negative() -> int {
  let opt = Some(-10)
  match opt {
    Some(x) if x > 0 => 1,
    Some(_) => 2,
    None => 3,
  }
}

fn test_guard_zero() -> int {
  let opt = Some(0)
  match opt {
    Some(x) if x > 0 => 1,
    Some(x) if x < 0 => 2,
    Some(_) => 3,
    None => 4,
  }
}

fn test_guard_none() -> int {
  let opt: Option<int> = None
  match opt {
    Some(x) if x > 0 => 1,
    Some(_) => 2,
    None => 3,
  }
}

fn test_guard_multiple() -> int {
  let opt = Some(50)
  match opt {
    Some(x) if x > 100 => 1,
    Some(x) if x > 50 => 2,
    Some(x) if x > 0 => 3,
    Some(_) => 4,
    None => 5,
  }
}

fn test_guard_uses_binding() -> int {
  let opt = Some(7)
  match opt {
    Some(n) if n > 10 => n * 10,
    Some(n) if n > 5 => n * 2,
    Some(n) => n,
    None => 0,
  }
}

fn test_guard_on_tuple() -> int {
  let pair = (3, 5)
  match pair {
    (x, y) if x == y => 1,
    (x, y) if x > y => 2,
    (x, y) if x < y => 3,
    _ => 4,
  }
}

fn test_guard_on_struct() -> int {
  let p = Point { x: 10, y: 10 }
  match p {
    Point { x, y } if x == y => 1,
    Point { x, y } if x > y => 2,
    _ => 3,
  }
}

fn test_guard_complex_condition() -> int {
  let pair = (3, 4)
  match pair {
    (x, y) if x > 0 && y > 0 && x + y > 5 => 1,
    (x, y) if x > 0 || y > 0 => 2,
    _ => 3,
  }
}

fn test_guard_with_result() -> int {
  let res = Ok(25)
  match res {
    Ok(n) if n > 50 => 1,
    Ok(n) if n > 20 => 2,
    Ok(_) => 3,
    Err(_) => 4,
  }
}

// per-field visibility

pub struct PublicPoint {
  pub x: int,
  pub y: int,
}

pub struct MixedPoint {
  pub x: int,
  y: int, // private
}

pub struct PrivateFields { a: int, b: int }

fn test_all_pub_fields() -> int {
  let p = PublicPoint { x: 10, y: 20 }
  p.x + p.y
}

fn test_mixed_visibility() -> int {
  // Within same module, both pub and private fields are accessible
  let p = MixedPoint { x: 100, y: 50 }
  p.x + p.y
}

fn test_all_private_fields() -> int {
  let p = PrivateFields { a: 7, b: 8 }
  p.a + p.b
}

fn test_pub_struct_spread() -> int {
  let p1 = PublicPoint { x: 5, y: 10 }
  let p2 = PublicPoint { x: 100, ..p1 }
  p2.x + p2.y
}

fn test_mixed_struct_spread() -> int {
  let p1 = MixedPoint { x: 3, y: 4 }
  let p2 = MixedPoint { x: 30, ..p1 }
  p2.x + p2.y
}

fn test_pub_field_pattern() -> int {
  let p = PublicPoint { x: 11, y: 22 }
  match p {
    PublicPoint { x, y } => x + y,
  }
}

fn test_mixed_field_pattern() -> int {
  let p = MixedPoint { x: 33, y: 44 }
  match p {
    MixedPoint { x, y } => x + y,
  }
}

impl PublicPoint {
