  let b = Box { value: 42 }
  b.get()
}

fn test_generic_method_string() -> int {
  let b = Box { value: "hello" }
  if b.get() == "hello" { 100 } else { 0 }
}

fn test_generic_method_chain() -> int {
  let b = Box { value: 10 }
  b
    .map(|x: int| -> int {
      x * 2
    })
    .get()
}

