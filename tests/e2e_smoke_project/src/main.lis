  if s == "hello" { 100 } else { 0 }
}

// Concurrency tests

fn test_channel_basic() -> int {
  let ch = Channel.new<int>()
  // Select with default on empty channel takes default
  select {
    let Some(v) = ch.receive() => v,
    _ => 42,
  }
}

fn test_channel_multiple() -> int {
  let ch1 = Channel.new<int>()
  let ch2 = Channel.new<int>()
  let ch3 = Channel.new<int>()
  // All empty, takes default
  select {
    match ch1.receive() {
      Some(v) => v,
      None => 100,
    },
    match ch2.receive() {
      Some(v) => v + 10,
      None => 100,
    },
    match ch3.receive() {
      Some(v) => v + 20,
      None => 100,
    },
    _ => 100,
  }
}

fn test_select_basic() -> int {
  let ch1 = Channel.new<int>()
  let ch2 = Channel.new<int>()
  select {
    match ch1.receive() {
      Some(x) => x,
      None => 50,
    },
    match ch2.receive() {
      Some(y) => y,
      None => 50,
    },
    _ => 50,
  }
}

fn test_select_default() -> int {
  let ch = Channel.new<int>()
  let result = select {
    let Some(v) = ch.receive() => v + 100,
    _ => 0,
  }
  result
}

fn test_task_spawn() -> int {
  // Just verify task spawning compiles and runs
  // The task runs asynchronously, we just verify main continues
  task {
    fmt.Print("")
  }
  100
}

fn test_buffered_channel() -> int {
  let ch = Channel.buffered<int>(2)
  // Buffered channel can accept sends without blocking (up to capacity)
  ch.send(10)
  ch.send(20)
  // Receive the values
  let v1 = match ch.receive() {
    Some(v) => v,
    None => 0,
  }
  let v2 = match ch.receive() {
    Some(v) => v,
    None => 0,
  }
  v1 + v2
}

fn test_blocking_send_receive() -> int {
  let ch = Channel.new<int>()
  task {
    ch.send(42)
  }
  // Blocking receive waits for the send
  match ch.receive() {
    Some(v) => v,
    None => 0,
  }
}

fn test_channel_iteration() -> int {
  let ch = Channel.buffered<int>(3)
  ch.send(1)
  ch.send(2)
  ch.send(3)
  ch.close()
  let mut sum = 0
  for v in ch {
    sum = sum + v
  }
  sum
}

fn test_channel_split() -> int {
  let ch = Channel.new<int>()
  let (tx, rx) = ch.split()
  task {
    tx.send(99)
  }
  match rx.receive() {
    Some(v) => v,
    None => 0,
  }
}

fn test_select_match_receive_value() -> int {
  let ch = Channel.buffered<int>(1)
  ch.send(42)
  select {
    match ch.receive() {
      Some(v) => v,
      None => 0,
    },
    _ => -1,
  }
}

fn test_select_match_receive_closed() -> int {
  let ch = Channel.buffered<int>(1)
  ch.close()
  select {
    match ch.receive() {
      Some(v) => v,
      None => 100,
    },
    _ => // Channel is closed, should take this arm
    -1,
  }
}

