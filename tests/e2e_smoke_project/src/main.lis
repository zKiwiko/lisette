}

fn test_pub_let_destructure() -> int {
  let p = PublicPoint { x: 5, y: 10 }
  let PublicPoint { x, y } = p
  x + y
}

fn test_enum_struct_let_destructure() -> int {
  let e = Event.Click { x: 30, y: 12 }
  match e {
    Event.Click { x, y } => {
      let Event.Click { x: a, y: b } = e else {
        return 0
      }
      a + b
    },
    _ => 0,
  }
}

