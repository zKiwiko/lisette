package main

import (
	"example.com/aws"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	b := aws.Bucket{}
	opt_1 := lisette.MakeOptionSome("hi")
	var ptr_2 *string
	if opt_1.Tag == lisette.OptionSome {
		ptr_2 = &opt_1.SomeVal
	}
	b.Name = ptr_2
}
