---
source: tests/spec/emit/concurrency.rs
description: "input: \nfn test() {\n  let ch = Channel.new<int>()\n  task {\n    let mut found = 0\n    found = 1\n    ch.send(found)\n  }\n  task {\n    let mut found = 0\n    found = 2\n    ch.send(found)\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() {
	ch := make(chan int)
	go func() {
		found := 0
		found = 1
		_ = lisette.ChannelSend(ch, found)
	}()
	go func() {
		found := 0
		found = 2
		_ = lisette.ChannelSend(ch, found)
	}()
}
