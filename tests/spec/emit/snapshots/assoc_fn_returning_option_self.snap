description: "input: \nstruct Thing {\n  name: string,\n}\n\nimpl Thing {\n  fn maybe_create(name: string) -> Option<Thing> {\n    if name.length() > 0 { Some(Thing { name: name }) }\n    else { None }\n  }\n}\n\nfn test() -> Option<Thing> {\n  Thing.maybe_create(\"hello\")\n}\n"
---
package main

import "fmt"

type Thing struct {
	name string
}

func (t Thing) String() string {
	return fmt.Sprintf("Thing { name: %v }", t.name)
}

func Thing_maybe_create(name string) (Thing, bool) {
	if len(name) > 0 {
		return Thing{name: name}, true
	}
	return *new(Thing), false
}

func test() (Thing, bool) {
	return Thing_maybe_create("hello")
}
