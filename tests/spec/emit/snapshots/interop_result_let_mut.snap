---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:strconv\"\n\nfn main() {\n  let mut f: fn(string) -> Result<int, error> = strconv.Atoi\n  let r = f(\"42\")\n  let _ = r\n  f = strconv.Atoi\n  let r2 = f(\"99\")\n  let _ = r2\n}\n"
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func main() {
	f := strconv.Atoi
	ret_1, ret_2 := f("42")
	var r lisette.Result[int, error]
	if ret_2 != nil {
		r = lisette.MakeResultErr[int, error](ret_2)
	} else {
		r = lisette.MakeResultOk[int, error](ret_1)
	}
	_ = r
	f = strconv.Atoi
	ret_4, ret_5 := f("99")
	var result_6 lisette.Result[int, error]
	if ret_5 != nil {
		result_6 = lisette.MakeResultErr[int, error](ret_5)
	} else {
		result_6 = lisette.MakeResultOk[int, error](ret_4)
	}
	_ = result_6
}
