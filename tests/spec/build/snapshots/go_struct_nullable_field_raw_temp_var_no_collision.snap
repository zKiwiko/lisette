// === main.go ===
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"runtime/debug"
)

func main() {
	opt_1 := lisette.MakeOptionNone[*debug.Module]()
	var unwrap_2 *debug.Module
	if opt_1.Tag == lisette.OptionSome {
		unwrap_2 = opt_1.SomeVal
	}
	mod_ := debug.Module{
		Path:    "example.com/mod",
		Version: "v1.0.0",
		Sum:     "",
		Replace: unwrap_2,
	}
	raw_3 := mod_.Replace
	option_4 := lisette.OptionFromNilable[*debug.Module](raw_3, raw_3 == nil)
	r := option_4
	raw_1 := 3
	fmt.Println(r)
	fmt.Println(raw_1)
}
