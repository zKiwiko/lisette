source: tests/spec/emit/expressions.rs
description: "input: \nstruct Point2D(int, int)\ntype P = Point2D\n\nfn test() -> P {\n  P(1, 2)\n}\n"
---
package main

import "fmt"

type Point2D struct {
	F0 int
	F1 int
}

func (p Point2D) String() string {
	return fmt.Sprintf("Point2D(%v, %v)", p.F0, p.F1)
}

type P = Point2D

func test() P {
	return Point2D{
		F0: 1,
		F1: 2,
	}
}
