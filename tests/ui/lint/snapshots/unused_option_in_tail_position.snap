  [error] Mismatch between return type and return value
   ╭─[test.lis:7:3]
 5 │ 
 6 │ fn do_search() {
   ·                ┬
   ·                ╰── has `()` as implicit return type
 7 │   find_item()
   ·   ─────┬─────
   ·        ╰── returns `Option<int>`
