fn report(name: string, result: int, expected: int) {
  if result == expected {
    fmt.Print(f"{name}: PASS\n")
  } else {
    fmt.Print(f"{name}: FAIL (got {result}, expected {expected})\n")
  }
}

fn section(name: string) {
  fmt.Print(f"\n// {name}\n\n") // pattern matching - tuples
}

fn test_tuple_literal() -> int {
  let pair = (1, 2)
  match pair {
    (1, 2) => 100,
    _ => 0,
  }
}

fn test_tuple_binding() -> int {
  let pair = (3, 4)
  match pair {
    (x, y) => x + y,
  }
}

fn test_tuple_mixed() -> int {
  let pair = (0, 42)
  match pair {
    (0, y) => y,
    (x, 0) => x,
    (x, y) => x + y,
  }
}

fn test_tuple_wildcard() -> int {
  let pair = (5, 10)
  match pair {
    (_, y) => y,
  }
}

fn test_tuple_nested() -> int {
  let nested = ((1, 2), 3)
  match nested {
    ((1, 2), 3) => 100,
    ((x, y), z) => x + y + z,
  }
}

fn test_tuple_first_match() -> int {
  let pair = (1, 1)
  match pair {
    (1, _) => 10,
    (_, 1) => 20,
    _ => 30,
  }
}

fn test_tuple_triple() -> int {
  let triple = (1, 2, 3)
  match triple {
    (1, 2, 3) => 6,
    (a, b, c) => a + b + c,
  }
}

fn test_tuple_deep() -> int {
  let deep = (((1, 2), 3), 4)
  match deep {
    (((a, b), c), d) => a + b + c + d,
  }
}

fn test_tuple_expr_arm() -> int {
  let pair = (2, 3)
  match pair {
    (x, y) => (x + y) * 2,
  }
}

fn test_tuple_all_wild() -> int {
  let pair = (99, 99)
  match pair {
    (_, _) => 1,
  }
}

fn get_pair() -> (int, int) {
  (10, 20)
}

fn test_tuple_return_annotation() -> int {
  let (a, b) = get_pair()
  a + b
}

// enums

pub enum Color {
  Red,
  Green,
  Blue,
}

fn test_enum_simple() -> int {
  let c = Color.Red
  match c {
    Color.Red => 1,
    Color.Green => 2,
    Color.Blue => 3,
  }
}

pub enum Status {
  Active,
  Inactive(int),
}

fn test_enum_with_data() -> int {
  let s = Status.Inactive(42)
  match s {
    Status.Active => 0,
    Status.Inactive(n) => n,
  }
}

pub enum Pair<A, B> {
  Both(A, B),
  Neither,
}

fn test_enum_multi_field() -> int {
  let p = Pair.Both(3, 4)
  match p {
    Pair.Both(a, b) => a + b,
    Pair.Neither => 0,
  }
}

fn test_enum_neither() -> int {
  let p: Pair<int, int> = Pair.Neither
  match p {
    Pair.Both(_, _) => 0,
    Pair.Neither => 100,
  }
}

pub enum Message {
  Quit,
  Move(int, int),
  Write(string),
}

// Enum with struct variants for testing
pub enum Event {
  Click { x: int, y: int },
  KeyPress { key: string, ctrl: bool },
  Resize { width: int, height: int },
  Close,
}

// Struct variants with distinct field names
pub enum TypeConflict {
  IntVal { int_value: int },
  StrVal { str_value: string },
}

// Mixed tuple and struct variants
pub enum Shape {
  Circle(int),
  Rectangle { width: int, height: int },
  Triangle { base: int, height: int },
}

// Struct variant pattern matching - basic
fn test_struct_variant_match() -> int {
  let e = Event.Click { x: 10, y: 20 }
  match e {
    Event.Click { x, y } => x + y,
    Event.KeyPress { key: _, ctrl: _ } => 0,
    Event.Resize { width: _, height: _ } => 0,
    Event.Close => 0,
  }
}

// Struct variant pattern matching - different variant
fn test_struct_variant_keypress() -> int {
  let e = Event.KeyPress { key: "a", ctrl: true }
  match e {
    Event.Click { x: _, y: _ } => 0,
    Event.KeyPress { key: _, ctrl } => if ctrl { 100 } else { 50 },
    Event.Resize { width: _, height: _ } => 0,
    Event.Close => 0,
  }
}

// Struct variant pattern matching - partial with rest
fn test_struct_variant_partial() -> int {
  let e = Event.Resize { width: 800, height: 600 }
  match e {
    Event.Click { .. } => 0,
    Event.KeyPress { .. } => 0,
    Event.Resize { width, .. } => width,
    Event.Close => 0,
  }
}

// Struct variant construction and matching
fn test_struct_variant_construction() -> int {
  let s = Shape.Rectangle { width: 10, height: 5 }
  match s {
    Shape.Circle(r) => r * r,
    Shape.Rectangle { width, height } => width * height,
    Shape.Triangle { base, height } => base * height / 2,
  }
}

// Mixed tuple and struct variants in same enum
fn test_mixed_variants() -> int {
  let s1 = Shape.Circle(5)
  let s2 = Shape.Rectangle { width: 4, height: 3 }
  let area1 = match s1 {
    Shape.Circle(r) => r * r,
    Shape.Rectangle { width, height } => width * height,
    Shape.Triangle { base, height } => base * height / 2,
  }
  let area2 = match s2 {
    Shape.Circle(r) => r * r,
    Shape.Rectangle { width, height } => width * height,
    Shape.Triangle { base, height } => base * height / 2,
  }
  area1 + area2
}

// Struct variant with unit variant
fn test_struct_variant_with_unit() -> int {
  let e = Event.Close
  match e {
    Event.Click { x, y } => x + y,
    Event.KeyPress { .. } => 50,
    Event.Resize { .. } => 75,
    Event.Close => 99,
  }
}

// If-let with struct variant
fn test_if_let_struct_variant() -> int {
  let e = Event.Click { x: 5, y: 10 }
  if let Event.Click { x, y } = e { x * y } else { 0 }
}

// Let-else with struct variant
fn test_let_else_struct_variant() -> int {
  let e = Event.Click { x: 7, y: 8 }
  let Event.Click { x, y } = e else {
    return 0
  }
  x + y
}

// Let-else with struct variant OR-pattern (tests binding declarations)
fn test_let_else_struct_variant_or() -> int {
  let e = Event.Click { x: 5, y: 12 }
  let Event.Click { x, y } | Event.Resize { width: x, height: y } = e else {
    return 0
  }
  x + y
}

// Struct variant field reordering
fn test_struct_variant_field_order() -> int {
  let e = Event.Click { x: 3, y: 7 }
  match e {
    // Fields can be matched in any order
    Event.Click { y, x } => y * 10 + x,
    _ => 0,
  }
}

// Struct variants with distinct field names
fn test_struct_variant_type_conflict() -> int {
  let d1 = TypeConflict.IntVal { int_value: 42 }
  let d2 = TypeConflict.StrVal { str_value: "hello" }

  let v1 = match d1 {
    TypeConflict.IntVal { int_value } => int_value,
    TypeConflict.StrVal { .. } => 0,
  }

  let v2 = match d2 {
    TypeConflict.IntVal { .. } => 0,
    TypeConflict.StrVal { str_value } => if str_value == "hello" {
      5
    } else {
      0
    },
  }

  v1 + v2 // 42 + 5 = 47
}

// Tuple variant with struct variant (distinct field names)
enum TupleStructConflict {
  Foo(int),
  Bar { bar_val: string },
}

fn test_tuple_struct_field_conflict() -> int {
  let t = TupleStructConflict.Foo(10)
  let s = TupleStructConflict.Bar { bar_val: "hello" }

  let v1 = match t {
    TupleStructConflict.Foo(x) => x,
    TupleStructConflict.Bar { .. } => 0,
  }

  let v2 = match s {
    TupleStructConflict.Foo(_) => 0,
    TupleStructConflict.Bar { bar_val } => if bar_val == "hello" {
      23
    } else {
      0
    },
  }

  v1 + v2 // 10 + 23 = 33
}

// Variant named "Tag" collides with the discriminant field
enum TagCollision {
  Tag(int),
  Other(string),
}

fn test_tag_variant_collision() -> int {
  let t = TagCollision.Tag(42)
  let o = TagCollision.Other("hello")

  let v1 = match t {
    TagCollision.Tag(x) => x,
    TagCollision.Other(_) => 0,
  }

  let v2 = match o {
    TagCollision.Tag(_) => 0,
    TagCollision.Other(s) => if s == "hello" { 8 } else { 0 },
  }

  v1 + v2 // 42 + 8 = 50
}

// Struct variant field named "tag" collides with the discriminant field
enum TagFieldCollision {
  Foo { tag: int },
  Bar(string),
}

fn test_tag_field_collision() -> int {
  let f = TagFieldCollision.Foo { tag: 25 }
  let b = TagFieldCollision.Bar("world")

  let v1 = match f {
    TagFieldCollision.Foo { tag } => tag,
    TagFieldCollision.Bar(_) => 0,
  }

  let v2 = match b {
    TagFieldCollision.Foo { .. } => 0,
    TagFieldCollision.Bar(s) => if s == "world" { 12 } else { 0 },
  }

  v1 + v2 // 25 + 12 = 37
}

fn test_enum_message() -> int {
  let m = Message.Move(10, 20)
  match m {
    Message.Quit => 0,
    Message.Move(x, y) => x + y,
    Message.Write(_) => 100,
  }
}

fn test_enum_nested() -> int {
  let outer = Some(Some(42))
  match outer {
    Some(Some(x)) => x,
    Some(None) => -1,
    None => -2,
  }
}

fn test_enum_nested_none() -> int {
  let outer: Option<Option<int>> = Some(None)
  match outer {
    Some(Some(x)) => x,
    Some(None) => -1,
    None => -2,
  }
}

fn test_enum_message_quit() -> int {
  let m = Message.Quit
  match m {
    Message.Quit => 0,
    Message.Move(x, y) => x + y,
    Message.Write(_) => 100,
  }
}

fn test_enum_message_write() -> int {
  let m = Message.Write("hello")
  match m {
    Message.Quit => 0,
    Message.Move(x, y) => x + y,
    Message.Write(_) => 100,
  }
}

fn test_enum_multi_arm() -> int {
  let s = Status.Active
  match s {
    Status.Inactive(n) => n,
    Status.Active => 999,
  } // pattern matching - slices
}

fn test_slice_empty() -> int {
  let arr: Slice<int> = []
  match arr {
    [] => 100,
    _ => 0,
  }
}

fn test_slice_single() -> int {
  let arr = [42]
  match arr {
    [x] => x,
    _ => 0,
  }
}

fn test_slice_fixed() -> int {
  let arr = [1, 2, 3]
  match arr {
    [a, b, c] => a + b + c,
    _ => 0,
  }
}

fn test_slice_fixed_mismatch() -> int {
  let arr = [1, 2]
  match arr {
    [a, b, c] => a + b + c,
    [a, b] => a + b,
    _ => 0,
  }
}

fn test_slice_rest_discard() -> int {
  let arr = [10, 20, 30, 40]
  match arr {
    [first, ..] => first,
    _ => 0,
  }
}

fn test_slice_rest_bind() -> int {
  let arr = [1, 2, 3, 4, 5]
  match arr {
    [first, ..rest] => first + rest[0],
    _ => 0,
  }
}

fn test_slice_literal_match() -> int {
  let arr = [1, 2]
  match arr {
    [1, 2] => 100,
    _ => 0,
  }
}

fn test_slice_mixed() -> int {
  let arr = [0, 99, 3]
  match arr {
    [0, x, _] => x,
    _ => 0,
  } // pattern matching - structs
}

struct Point { x: int, y: int }

fn test_struct_full() -> int {
  let p = Point { x: 3, y: 4 }
  match p {
    Point { x, y } => x + y,
  }
}

fn test_struct_literal() -> int {
  let p = Point { x: 0, y: 42 }
  match p {
    Point { x: 0, y } => y,
    Point { x, y: 0 } => x,
    Point { x, y } => x + y,
  }
}

fn test_struct_renamed() -> int {
  let p = Point { x: 10, y: 20 }
  match p {
    Point { x: a, y: b } => a * b,
  }
}

fn test_struct_partial() -> int {
  let p = Point { x: 10, y: 20 }
  match p {
    Point { x, .. } => x,
  }
}

struct Rect { origin: Point, width: int, height: int }

fn test_struct_nested() -> int {
  let r = Rect { origin: Point { x: 1, y: 2 }, width: 10, height: 20 }
  match r {
    Rect { origin: Point { x, y }, width, height } => x + y + width + height,
  }
}

fn test_struct_wildcard_field() -> int {
  let p = Point { x: 5, y: 10 }
  match p {
    Point { x: _, y } => y,
  }
}

fn test_struct_multiple_arms() -> int {
  let p = Point { x: 0, y: 5 }
  match p {
    Point { x: 0, y: 0 } => 0,
    Point { x: 0, y } => y,
    Point { x, y: 0 } => x,
    Point { x, y } => x + y,
  }
}

fn test_struct_let_destructure() -> int {
  let p = Point { x: 7, y: 8 }
  let Point { x, y } = p
  x + y // Option
}

fn test_option_some() -> int {
  let x = Some(42)
  match x {
    Some(n) => n,
    None => 0,
  }
}

fn test_option_none() -> int {
  let x: Option<int> = None
  match x {
    Some(n) => n,
    None => -1,
  }
}

fn test_option_chain() -> int {
  let a = Some(5)
  let b = Some(10)
  match (a, b) {
    (Some(x), Some(y)) => x + y,
    _ => 0,
  }
}

fn get_option() -> Option<int> {
  Some(10)
}

fn test_option_passthrough() -> int {
  let x = get_option()
  match x {
    Some(n) => n,
    None => 0,
  }
}

fn maybe_double(x: int) -> Option<int> {
  if x > 0 { Some(x * 2) } else { None }
}

fn test_option_conditional() -> int {
  match maybe_double(5) {
    Some(n) => n,
    None => 0,
  }
}

fn test_option_conditional_none() -> int {
  match maybe_double(-1) {
    Some(n) => n,
    None => -1,
  }
}

fn test_option_nested() -> int {
  let x: Option<Option<int>> = Some(Some(42))
  match x {
    Some(Some(n)) => n,
    Some(None) => -1,
    None => -2,
  }
}

struct Container { value: Option<int> }

fn test_option_in_struct() -> int {
  let c = Container { value: Some(99) }
  match c.value {
    Some(n) => n,
    None => 0,
  }
}

fn get_some() -> Option<int> {
  Some(123)
}

fn test_option_return_some() -> int {
  match get_some() {
    Some(n) => n,
    None => 0,
  }
}

fn get_none() -> Option<int> {
  None
}

fn test_option_return_none() -> int {
  match get_none() {
    Some(n) => n,
    None => -1,
  }
}

// if let

fn test_if_let_some() -> int {
  let opt = Some(42)
  if let Some(x) = opt { x } else { 0 }
}

fn test_if_let_none() -> int {
  let opt: Option<int> = None
  if let Some(x) = opt { x } else { -1 }
}

fn test_if_let_statement() -> int {
  let opt = Some(10)
  let mut result = 0
  if let Some(x) = opt { result = x + 5 }
  result
}

fn test_if_let_nested() -> int {
  let opt: Option<Option<int>> = Some(Some(100))
  if let Some(inner) = opt {
    if let Some(x) = inner { x } else { -1 }
  } else {
    -2
  }
}

fn test_if_let_else_if_let() -> int {
  let a: Option<int> = None
  let b = Some(77)
  if let Some(x) = a { x } else if let Some(y) = b { y } else { 0 }
}

fn test_if_let_result_ok() -> int {
  let res = Ok(55)
  if let Ok(x) = res { x } else { -1 }
}

fn test_if_let_result_err() -> int {
  let res: Result<int, string> = Err("oops")
  if let Ok(x) = res { x } else { -1 }
}

// let else

fn test_let_else_some() -> int {
  let opt = Some(42)
  let Some(x) = opt else {
    return -1
  }
  x
}

fn test_let_else_none() -> int {
  let opt: Option<int> = None
  let Some(x) = opt else {
    return -1
  }
  x
}

fn test_let_else_result_ok() -> int {
  let res = Ok(55)
  let Ok(x) = res else {
    return -1
  }
  x
}

fn test_let_else_result_err() -> int {
  let res: Result<int, string> = Err("oops")
  let Ok(x) = res else {
    return -1
  }
  x
}

fn test_let_else_with_computation() -> int {
  let opt = Some(10)
  let Some(x) = opt else {
    return 0
  }
  x * 2 + 5
}

fn test_let_else_chained() -> int {
  let a: Option<int> = None
  let b = Some(20)

  let Some(x) = a else {
    let Some(y) = b else {
      return -1
    }
    return y
  }
  x
}

fn helper_let_else_in_loop(items: Slice<Option<int>>) -> int {
  let mut sum = 0
  for item in items {
    let Some(x) = item else {
      continue
    }
    sum = sum + x
  }
  sum
}

fn test_let_else_in_loop() -> int {
  let items = [Some(1), None, Some(2), None, Some(3)]
  helper_let_else_in_loop(items)
}

fn helper_let_else_break(items: Slice<Option<int>>) -> int {
  let mut result = 0
  for item in items {
    let Some(x) = item else {
      break
    }
    result = result + x
  }
  result
}

fn test_let_else_break() -> int {
  let items = [Some(1), Some(2), None, Some(100)]
  helper_let_else_break(items)
}

// while let

fn test_while_let_basic() -> int {
  let mut opt = Some(3)
  let mut sum = 0
  while let Some(x) = opt {
    sum = sum + x
    if x <= 1 { opt = None } else { opt = Some(x - 1) }
  }
  sum
}

fn test_while_let_none_initially() -> int {
  let opt: Option<int> = None
  let mut count = 0
  while let Some(_) = opt {
    count = count + 1
  }
  count
}

fn test_while_let_with_break() -> int {
  let mut opt = Some(10)
  let mut sum = 0
  while let Some(x) = opt {
    if x > 100 { break }
    sum = sum + x
    opt = Some(x * 2)
  }
  sum
}

fn test_while_let_tuple() -> int {
  let mut opt = Some((1, 2))
  let mut sum = 0
  while let Some((a, b)) = opt {
    sum = sum + a + b
    opt = None
  }
  sum
}

fn test_while_let_result() -> int {
  let mut res = Ok(5)
  let mut sum = 0
  while let Ok(x) = res {
    sum = sum + x
    if x <= 1 { res = Err("done") } else { res = Ok(x - 1) }
  }
  sum
}

// Result

fn test_result_ok() -> int {
  let x = Ok(42)
  match x {
    Ok(n) => n,
    Err(_) => -1,
  }
}

fn test_result_err() -> int {
  let x: Result<int, string> = Err("failed")
  match x {
    Ok(n) => n,
    Err(_) => -1,
  }
}

fn fallible() -> Result<int, string> {
  Ok(10)
}

fn fallible_propagate() -> Result<int, string> {
  let x = fallible()?
  Ok(x + 1)
}

fn test_result_propagation() -> int {
  match fallible_propagate() {
    Ok(n) => n,
    Err(_) => -1,
  }
}

fn test_result_chain() -> int {
  let a = Ok(5)
  let b = Ok(10)
  match (a, b) {
    (Ok(x), Ok(y)) => x + y,
    _ => -1,
  }
}

fn test_result_mixed() -> int {
  let a = Ok(5)
  let b: Result<int, string> = Err("oops")
  match (a, b) {
    (Ok(x), Ok(y)) => x + y,
    (Ok(x), Err(_)) => x,
    (Err(_), Ok(y)) => y,
    (Err(_), Err(_)) => -1,
  }
}

fn fallible_err() -> Result<int, string> {
  Err("error")
}

fn fallible_propagate_err() -> Result<int, string> {
  let x = fallible_err()?
  Ok(x + 1)
}

fn test_result_propagation_err() -> int {
  match fallible_propagate_err() {
    Ok(n) => n,
    Err(_) => -1,
  }
}

fn multi_fallible() -> Result<int, string> {
  let a = fallible()?
  let b = fallible()?
  Ok(a + b)
}

fn test_result_multi_propagation() -> int {
  match multi_fallible() {
    Ok(n) => n,
    Err(_) => -1,
  }
}

fn check_error(e: string) -> int {
  if e == "specific error" { 42 } else { -1 }
}

fn test_result_err_value() -> int {
  let x: Result<int, string> = Err("specific error")
  match x {
    Ok(_) => 0,
    Err(e) => check_error(e),
  }
}

// try blocks

fn try_risky_ok() -> Result<int, string> {
  Ok(42)
}

fn try_risky_err() -> Result<int, string> {
  Err("error")
}

fn try_maybe_some() -> Option<int> {
  Some(10)
}

fn try_maybe_none() -> Option<int> {
  None
}

fn test_try_block_basic() -> int {
  let result = try {
    try_risky_ok()?
  }
  match result {
    Ok(x) => x,
    Err(_) => 0,
  }
}

fn test_try_block_multiple() -> int {
  let result = try {
    let a = try_risky_ok()?
    let b = try_risky_ok()?
    a + b
  }
  match result {
    Ok(x) => x,
    Err(_) => 0,
  }
}

fn test_try_block_early_err() -> int {
  let result: Result<int, string> = try {
    let _ = try_risky_err()?
    100
  }
  match result {
    Ok(_) => 0,
    Err(_) => 42,
  }
}

fn test_try_block_option() -> int {
  let opt = try {
    let x = try_maybe_some()?
    x + 5
  }
  match opt {
    Some(v) => v,
    None => 0,
  }
}

fn test_try_block_option_none() -> int {
  let opt: Option<int> = try {
    let _ = try_maybe_none()?
    100
  }
  match opt {
    Some(_) => 0,
    None => 42,
  }
}

fn test_try_block_nested() -> int {
  let outer = try {
    let inner: Result<int, string> = try {
      try_risky_ok()?
    }
    let inner_val = match inner {
      Ok(x) => x,
      Err(_) => 0,
    }
    inner_val + try_risky_ok()?
  }
  match outer {
    Ok(x) => x,
    Err(_) => 0,
  }
}

fn test_try_block_with_loop() -> int {
  let result = try {
    let mut sum = 0
    for i in 0..3 {
      if i > 1 { break }
      sum = sum + i
    }
    sum + try_risky_ok()?
  }
  match result {
    Ok(x) => x,
    Err(_) => 0,
  }
}

fn test_try_block_conditional() -> int {
  let result = try {
    if true { try_risky_ok()? } else { 0 }
  }
  match result {
    Ok(x) => x,
    Err(_) => 0,
  }
}

// Control flow tests

fn test_if_true() -> int {
  if true { 100 } else { 0 }
}

fn test_if_false() -> int {
  if false { 0 } else { 100 }
}

fn test_if_chain() -> int {
  let x = 2
  if x == 1 { 1 } else if x == 2 { 2 } else if x == 3 { 3 } else { 0 }
}

fn test_if_nested() -> int {
  let x = 5
  let y = 10
  if x > 0 { if y > 5 { 100 } else { 50 } } else { 0 }
}

fn test_while_loop() -> int {
  let mut sum = 0
  let mut i = 1
  while i <= 10 {
    sum = sum + i
    i = i + 1
  }
  sum
}

fn test_for_loop() -> int {
  let mut sum = 0
  for i in [1, 2, 3, 4, 5] {
    sum = sum + i
  }
  sum
}

fn test_range_exclusive() -> int {
  let mut sum = 0
  for i in 0..5 {
    sum = sum + i
  }
  sum
}

fn test_range_inclusive() -> int {
  let mut sum = 0
  for i in 0..=4 {
    sum = sum + i
  }
  sum
}

fn test_range_from() -> int {
  let mut sum = 0
  for i in 3.. {
    if i >= 6 { break }
    sum = sum + i
  }
  sum
}

fn test_stored_range() -> int {
  let r = 0..5
  let mut sum = 0
  for i in r {
    sum = sum + i
  }
  sum
}

fn test_slice_range_exclusive() -> int {
  let arr = [10, 20, 30, 40, 50]
  let sub = arr[1..4]
  sub[0] + sub[1] + sub[2]
}

fn test_slice_range_inclusive() -> int {
  let arr = [10, 20, 30, 40, 50]
  let sub = arr[1..=3]
  sub[0] + sub[1] + sub[2]
}

fn test_slice_range_from() -> int {
  let arr = [10, 20, 30, 40, 50]
  let sub = arr[2..]
  sub[0] + sub[1] + sub[2]
}

fn test_slice_range_to() -> int {
  let arr = [10, 20, 30, 40, 50]
  let sub = arr[..3]
  sub[0] + sub[1] + sub[2]
}

fn test_slice_range_full() -> int {
  let arr = [10, 20, 30]
  let sub = arr[..]
  sub[0] + sub[1] + sub[2]
}

fn test_subslice_append_no_alias() -> int {
  // Sub-slicing caps capacity, so append on a sub-slice must not
  // corrupt the original. This is the CVE-2021-39137 class of bug.
  let source = [1, 2, 3, 4, 5]
  let sub = source[1..3]
  let _ = sub.append(99)
  // If aliasing occurred, source[3] would be 99 instead of 4.
  source[3]
}

fn test_mutable_subslice_element_write_no_alias() -> int {
  let source = [1, 2, 3, 4, 5]
  let mut sub = source[1..3]
  sub[0] = 99
  // If aliasing occurred, source[1] would be 99 instead of 2.
  source[1]
}

fn test_loop_break() -> int {
  let mut i = 0
  loop {
    i = i + 1
    if i == 5 { break }
  }
  i
}

fn test_loop_continue() -> int {
  let mut sum = 0
  let mut i = 0
  while i < 10 {
    i = i + 1
    if i % 2 == 0 { continue }
    sum = sum + i
  }
  sum
}

fn test_nested_loop() -> int {
  let mut count = 0
  for _ in [1, 2, 3] {
    for _ in [1, 2, 3] {
      count = count + 1
    }
  }
  count
}

fn early_return_helper(x: int) -> int {
  if x < 0 { return -1 }
  if x == 0 { return 0 }
  x * 2
}

fn test_early_return() -> int {
  early_return_helper(-5) + early_return_helper(0) + early_return_helper(10) // Functions tests
}

fn add(a: int, b: int) -> int {
  a + b
}

fn test_fn_call() -> int {
  add(3, 4)
}

fn apply(f: fn(int) -> int, x: int) -> int {
  f(x)
}

fn double(x: int) -> int {
  x * 2
}

fn test_higher_order() -> int {
  apply(double, 5)
}

fn test_lambda_simple() -> int {
  let f = |x: int| -> int {
    x + 1
  }
  f(99)
}

fn test_lambda_capture() -> int {
  let y = 10
  let f = |x: int| -> int {
    x + y
  }
  f(5)
}

fn factorial(n: int) -> int {
  if n <= 1 { 1 } else { n * factorial(n - 1) }
}

fn test_recursion() -> int {
  factorial(5)
}

impl Point {
