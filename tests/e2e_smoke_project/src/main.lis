// Early return from nested contexts

fn deeply_nested(x: int) -> int {
  if x > 0 {
    match x {
      1 => {
        for i in [1, 2, 3] {
          if i == 2 { return 200 }
        }
        100
      },
      _ => x,
    }
  } else {
    -1
  }
}

