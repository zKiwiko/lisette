// === main.go ===
package main

import (
	"flag"
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	raw_1 := flag.Lookup("verbose")
	option_2 := lisette.OptionFromNilable[*flag.Flag](raw_1, raw_1 == nil)
	result := option_2
	fmt.Print(result.IsSome())
}
