---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn maybe(x: int) -> Option<int> {\n  if x > 0 { Some(x) } else { None }\n}\n\nfn test() {\n  let arr = [maybe(1), maybe(0), maybe(3), maybe(-1)];\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func maybe(x int) (int, bool) {
	if x > 0 {
		return x, true
	}
	return *new(int), false
}

func test() {
	option_1 := lisette.OptionFromCommaOk[int](maybe(1))
	option_2 := lisette.OptionFromCommaOk[int](maybe(0))
	option_3 := lisette.OptionFromCommaOk[int](maybe(3))
	option_4 := lisette.OptionFromCommaOk[int](maybe(-1))
	_ = []lisette.Option[int]{option_1, option_2, option_3, option_4}
}
