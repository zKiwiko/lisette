---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:strconv\"\n\nfn main() {\n  let t: (fn(string) -> Result<int, error>, int) = (strconv.Atoi, 1)\n  let r = t.0(\"1\")\n  match r {\n    Ok(v) => { let _ = v },\n    Err(_) => { let _ = 0 },\n  }\n}\n"
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func main() {
	t := lisette.MakeTuple2(strconv.Atoi, 1)
	ret_1, ret_2 := t.First("1")
	var r lisette.Result[int, error]
	if ret_2 != nil {
		r = lisette.MakeResultErr[int, error](ret_2)
	} else {
		r = lisette.MakeResultOk[int, error](ret_1)
	}
	if r.Tag == lisette.ResultOk {
		_ = r.OkVal
	} else {
		_ = 0
	}
}
