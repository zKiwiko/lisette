source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:os\"\n\nfn make_lookup() -> fn(string) -> Option<string> {\n  os.LookupEnv\n}\n\nfn main() {\n  let f = make_lookup()\n  let r = f(\"HOME\")\n  match r {\n    Some(v) => { let _ = v },\n    None => { let _ = \"\" },\n  }\n}\n"
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"os"
)

func make_lookup() func(string) (string, bool) {
	return os.LookupEnv
}

func main() {
	f := make_lookup()
	option_1 := lisette.OptionFromCommaOk[string](f("HOME"))
	r := option_1
	if r.Tag == lisette.OptionSome {
		_ = r.SomeVal
	} else {
		_ = ""
	}
}
