source: tests/spec/emit/go_interface_adapter.rs
description: "input: \nimport \"go:example.com/idx\"\n\nfn main() {\n  let pos = idx.Find(\"hello\", \"lo\")\n  let _ = match pos {\n    Some(i) => i,\n    None => -2,\n  }\n}\n"
---
package main

import (
	"example.com/idx"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	ret_1 := idx.Find("hello", "lo")
	option_2 := lisette.OptionFromCommaOk[int](ret_1, ret_1 != -1)
	pos := option_2
	var tmp_3 int
	if pos.Tag == lisette.OptionSome {
		tmp_3 = pos.SomeVal
	} else {
		tmp_3 = -2
	}
	_ = tmp_3
}
