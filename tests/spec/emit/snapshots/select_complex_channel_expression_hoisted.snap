---
source: tests/spec/emit/concurrency.rs
description: "input: \nfn main() {\n  let ch1 = Channel.buffered<int>(1)\n  let ch2 = Channel.buffered<int>(1)\n  ch1.send(1)\n  ch2.send(2)\n  let flag = true\n  let ch = if flag { ch1 } else { ch2 }\n  select {\n    let Some(v) = ch.receive() => {\n      let _ = v\n    },\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func main() {
	ch1 := make(chan int, 1)
	ch2 := make(chan int, 1)
	_ = lisette.ChannelSend(ch1, 1)
	_ = lisette.ChannelSend(ch2, 2)
	flag := true
	var ch_1 chan int
	if flag {
		ch_1 = ch1
	} else {
		ch_1 = ch2
	}
	for {
		select {
		case v, ok := <-ch_1:
			if ok {
				_ = v
			} else {
				ch_1 = nil
				continue
			}
		}
		break
	}
}
