import "go:fmt"

fn check(name: string, got: int, want: int) -> bool {
  if got == want {
    fmt.Println("PASS", name, "got", got)
    true
  } else {
    fmt.Println("FAIL", name, "got", got, "want", want)
    false
  }
}

fn main() {
  let mut passed = 0
  let mut failed = 0

  if check("xor basic", 10 ^ 5, 15) { passed += 1 } else { failed += 1 }
  if check("and basic", 10 & 5, 0) { passed += 1 } else { failed += 1 }
  if check("or basic", 10 | 5, 15) { passed += 1 } else { failed += 1 }
  if check("andnot basic", 10 &^ 5, 10) { passed += 1 } else { failed += 1 }
  if check("shl basic", 3 << 2, 12) { passed += 1 } else { failed += 1 }
  if check("shr basic", 32 >> 3, 4) { passed += 1 } else { failed += 1 }

  if check("xor identity 0", 0 ^ 123, 123) { passed += 1 } else { failed += 1 }
  if check("and identity all-ones style", 255 & 42, 42) { passed += 1 } else { failed += 1 }
  if check("or identity 0", 0 | 77, 77) { passed += 1 } else { failed += 1 }
  if check("andnot clear low bits", 0b1111 &^ 0b0011, 12) { passed += 1 } else { failed += 1 }

  if check("left assoc xor", 1 ^ 2 ^ 3, 0) { passed += 1 } else { failed += 1 }
  if check("left assoc and", 7 & 3 & 1, 1) { passed += 1 } else { failed += 1 }
  if check("left assoc or", 1 | 2 | 4, 7) { passed += 1 } else { failed += 1 }

  if check("precedence mul over xor", 2 ^ 3 * 4, 14) { passed += 1 } else { failed += 1 }
  if check("precedence shift over plus lhs", 1 + 2 << 3, 17) { passed += 1 } else { failed += 1 }
  if check("precedence shift over plus rhs", 32 >> 3 + 1, 5) { passed += 1 } else { failed += 1 }
  if check("paren override", (1 + 2) << (3 + 1), 48) { passed += 1 } else { failed += 1 }

  if check("mix and/or/xor", (0b1010 & 0b1111) ^ (0b0011 | 0b0100), 13) {
    passed += 1
  } else {
    failed += 1
  }

  if check("compound expression 1", (5 << 4) &^ (3 << 2), 80) {
    passed += 1
  } else {
    failed += 1
  }

  if check("compound expression 2", ((255 &^ 15) >> 4) ^ 3, 12) {
    passed += 1
  } else {
    failed += 1
  }

  fmt.Println("-----")
  fmt.Println("bitwise tests passed:", passed, "failed:", failed)
}

// Result
// PASS xor basic got 15
// PASS and basic got 0
// PASS or basic got 15
// PASS andnot basic got 10
// PASS shl basic got 12
// PASS shr basic got 4
// PASS xor identity 0 got 123
// PASS and identity all-ones style got 42
// PASS or identity 0 got 77
// PASS andnot clear low bits got 12
// PASS left assoc xor got 0
// PASS left assoc and got 1
// PASS left assoc or got 7
// PASS precedence mul over xor got 14
// PASS precedence shift over plus lhs got 17
// PASS precedence shift over plus rhs got 5
// PASS paren override got 48
// PASS mix and/or/xor got 13
// PASS compound expression 1 got 80
// PASS compound expression 2 got 12
// -----
// bitwise tests passed: 20 failed: 0