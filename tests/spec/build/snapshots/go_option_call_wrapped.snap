// === main.go ===
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"go/doc/comment"
)

func main() {
	option_1 := lisette.OptionFromCommaOk[string](comment.DefaultLookupPackage("math"))
	result := option_1
	fmt.Print(result.IsSome())
}
