}

/// A TypeSwitchStmt node represents a type switch statement.
pub struct TypeSwitchStmt {
  pub Switch: token.Pos,
  pub Init: Option<Stmt>,
  pub Assign: Option<Stmt>,
  pub Body: Option<Ref<BlockStmt>>,
}

/// A UnaryExpr node represents a unary expression.
/// Unary "*" expressions are represented via StarExpr nodes.
pub struct UnaryExpr {
  pub OpPos: token.Pos,
  pub Op: token.Token,
  pub X: Option<Expr>,
}

/// A ValueSpec node represents a constant or variable declaration
/// (ConstSpec or VarSpec production).
pub struct ValueSpec {
  pub Doc: Option<Ref<CommentGroup>>,
  pub Names: Slice<Option<Ref<Ident>>>,
  pub Type: Option<Expr>,
  pub Values: Slice<Option<Expr>>,
  pub Comment: Option<Ref<CommentGroup>>,
}

/// A Visitor's Visit method is invoked for each node encountered by [Walk].
/// If the result visitor w is not nil, [Walk] visits each of the children
/// of node with the visitor w, followed by a call of w.Visit(nil).
pub interface Visitor {
  fn Visit(node: Node) -> Visitor
}

pub const FilterFuncDuplicates: MergeMode = 1

pub const FilterImportDuplicates: MergeMode = 4

pub const FilterUnassociatedComments: MergeMode = 2

pub const RECV: ChanDir = 2

pub const SEND: ChanDir = 1

