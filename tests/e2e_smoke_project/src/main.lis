fn test_nested_field_assignment() -> int {
  let mut outer = Outer { middle: Middle { inner: Inner { value: 0 } } }
  outer.middle.inner.value = 42
  outer.middle.inner.value
}

// complex control flow

fn test_break_nested_labeled() -> int {
  let mut sum = 0
  let mut i = 0
  loop {
    i += 1
    let mut j = 0
    loop {
      j += 1
      sum += 1
      if j >= 3 { break }
    }
    if i >= 4 { break }
  }
  sum
}

fn test_continue_in_nested() -> int {
  let mut count = 0
  for _ in [1, 2, 3] {
    for j in [1, 2, 3] {
      if j == 2 { continue }
      count += 1
    }
  }
  count
}

// custom generic enum

enum Either<L, R> {
  Left(L),
  Right(R),
}

fn test_either_left() -> int {
  let e: Either<int, string> = Either.Left(42)
  match e {
    Either.Left(v) => v,
    Either.Right(_) => 0,
  }
}

fn test_either_right() -> int {
  let e: Either<int, string> = Either.Right("hello")
  match e {
    Either.Left(_) => 0,
    Either.Right(s) => if s == "hello" { 100 } else { 0 },
  }
}

// enum methods (regression test for method call capitalization bug)

enum MethodEnum {
  Val(int),
  Empty,
}

impl MethodEnum {
