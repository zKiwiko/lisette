---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn get_value() -> Option<int> {\n  Some(99)\n}\n\nfn test(flag: bool) -> Option<int> {\n  if flag { Some(42) } else { get_value() }\n}\n"
---
package main

func get_value() (int, bool) {
	return 99, true
}

func test(flag bool) (int, bool) {
	if flag {
		return 42, true
	}
	return get_value()
}
