---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:strconv\"\n\nfn make_parser() -> fn(string) -> Result<int, error> {\n  strconv.Atoi\n}\n\nfn main() {\n  let f = make_parser()\n  let r = f(\"42\")\n  match r {\n    Ok(v) => { let _ = v },\n    Err(_) => { let _ = 0 },\n  }\n}\n"
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func make_parser() func(string) (int, error) {
	return strconv.Atoi
}

func main() {
	f := make_parser()
	ret_1, ret_2 := f("42")
	var r lisette.Result[int, error]
	if ret_2 != nil {
		r = lisette.MakeResultErr[int, error](ret_2)
	} else {
		r = lisette.MakeResultOk[int, error](ret_1)
	}
	if r.Tag == lisette.ResultOk {
		_ = r.OkVal
	} else {
		_ = 0
	}
}
