---
source: tests/spec/emit/control_flow.rs
description: "input: \nenum E {\n  A(int),\n  B(int),\n  C,\n}\nfn test() {\n  let x = 5\n  let e = E.A(9)\n  let E.A(y) | E.B(y) = e else {\n    return\n  }\n  if y != 9 { panic(\"pattern\") }\n  if x != 5 { panic(\"outer\") }\n}\n"
---
package main

import "fmt"

func MakeEA(arg0 int) E {
	return E{Tag: EA, A: arg0}
}

func MakeEB(arg0 int) E {
	return E{Tag: EB, B: arg0}
}

func MakeEC() E {
	return E{Tag: EC}
}

type ETag int

const (
	EA ETag = iota
	EB
	EC
)

type E struct {
	Tag ETag
	A   int
	B   int
}

func (e E) String() string {
	switch e.Tag {
	case EA:
		return fmt.Sprintf("E.A(%v)", e.A)
	case EB:
		return fmt.Sprintf("E.B(%v)", e.B)
	case EC:
		return "E.C"
	default:
		return fmt.Sprintf("E(%d)", e.Tag)
	}
}

func test() {
	x := 5
	e := MakeEA(9)
	var y int
	if e.Tag == EA {
		y = e.A
	} else if e.Tag == EB {
		y = e.B
	} else {
		return
	}
	if y != 9 {
		panic("pattern")
	}
	if x != 5 {
		panic("outer")
	}
}
