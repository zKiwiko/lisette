---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn f() -> Option<int> {\n  None?\n}\n\nfn test() -> Option<int> {\n  f()\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func f() (int, bool) {
	check_1 := lisette.MakeOptionNone[lisette.Option[int]]()
	if check_1.Tag != lisette.OptionSome {
		return *new(int), false
	}
	result_2 := check_1.SomeVal
	v_3 := result_2
	if v_3.Tag == lisette.OptionSome {
		return v_3.SomeVal, true
	}
	return *new(int), false
}

func test() (int, bool) {
	return f()
}
