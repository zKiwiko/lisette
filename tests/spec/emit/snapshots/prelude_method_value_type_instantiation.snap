description: "input: \nfn main() {\n  let f = Option.map\n  let x = f(Some(1), |v| v + 1)\n  let _ = x\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func main() {
	f := lisette.OptionMap[int, int]
	option_1 := lisette.OptionFromCommaOk[int](f(lisette.MakeOptionSome(1), func(v int) int {
		return v + 1
	}))
	_ = option_1
}
