---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:crypto/sha256\"\n\nfn main() {\n  let f: fn(Slice<uint8>) -> Slice<uint8> = if true {\n    sha256.Sum256\n  } else {\n    sha256.Sum224\n  }\n  let data: Slice<uint8> = []\n  let out = f(data)\n  let _ = out\n}\n"
---
package main

import "crypto/sha256"

func main() {
	var f func([]uint8) []uint8
	if true {
		f = func(arg0 []byte) []byte {
			arr_1 := sha256.Sum256(arg0)
			return arr_1[:]
		}
	} else {
		f = func(arg0 []byte) []byte {
			arr_2 := sha256.Sum224(arg0)
			return arr_2[:]
		}
	}
	data := []uint8{}
	_ = f(data)
}
