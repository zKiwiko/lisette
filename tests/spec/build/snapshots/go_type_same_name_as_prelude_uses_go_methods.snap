// === main.go ===
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"sync"
)

func main() {
	m := sync.Map{}
	m.Store("key", "value")
	option_2 := lisette.OptionFromCommaOk[any](m.Load("key"))
	subject_1 := option_2
	if subject_1.Tag == lisette.OptionSome {
		v := subject_1.SomeVal
		fmt.Printf("got: %v\n", v)
	} else {
		fmt.Println("not found")
	}
}
