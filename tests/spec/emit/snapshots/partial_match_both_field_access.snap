---
source: tests/spec/emit/partial.rs
description: "input: \nfn test(p: Partial<int, string>) -> string {\n  match p {\n    Partial.Ok(_) => \"ok\",\n    Partial.Err(e) => e,\n    Partial.Both(_, e) => e,\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(p lisette.Partial[int, string]) string {
	switch p.Tag {
	case lisette.PartialOk:
		return "ok"
	case lisette.PartialErr:
		e := p.ErrVal
		return e
	default:
		e := p.ErrVal
		return e
	}
}
