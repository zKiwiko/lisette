description: "input: \nfn test(s: Slice<int>, i: int) -> Option<int> {\n  s.get(i)\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(s []int, i int) (int, bool) {
	v_1 := lisette.SliceGet(s, i)
	if v_1.Tag == lisette.OptionSome {
		return v_1.SomeVal, true
	}
	return *new(int), false
}
