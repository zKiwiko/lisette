{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lisette",
  "scopeName": "source.lisette",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#attributes" },
    { "include": "#numbers" },
    { "include": "#function-definitions" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#function-calls" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.lisette",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.lisette",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.raw.lisette",
          "begin": "r\"",
          "end": "\"",
          "patterns": []
        },
        {
          "name": "string.interpolated.lisette",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            { "include": "#escape-sequences" },
            { "include": "#interpolation" }
          ]
        },
        {
          "name": "string.quoted.double.lisette",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#escape-sequences" }
          ]
        }
      ]
    },
    "escape-sequences": {
      "patterns": [
        {
          "name": "constant.character.escape.lisette",
          "match": "\\\\[nrt0\\\\\"']"
        },
        {
          "name": "constant.character.escape.lisette",
          "match": "\\\\x[0-9a-fA-F]{2}"
        },
        {
          "name": "constant.character.escape.lisette",
          "match": "\\\\u[0-9a-fA-F]{4}"
        },
        {
          "name": "constant.character.escape.lisette",
          "match": "\\\\U[0-9a-fA-F]{8}"
        }
      ]
    },
    "interpolation": {
      "name": "meta.interpolation.lisette",
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.section.interpolation.begin.lisette" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.interpolation.end.lisette" }
      },
      "patterns": [
        { "include": "source.lisette" }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "constant.character.lisette",
          "match": "'(\\\\[nrt0\\\\']|\\\\x[0-9a-fA-F]{2}|[^'\\\\])'"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.annotation.lisette",
          "begin": "#\\[",
          "end": "\\]",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.annotation.begin.lisette" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.annotation.end.lisette" }
          },
          "patterns": [
            {
              "name": "entity.name.tag.annotation.lisette",
              "match": "\\b\\w+\\b"
            },
            { "include": "#strings" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.imaginary.lisette",
          "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9_]+)?i\\b"
        },
        {
          "name": "constant.numeric.hex.lisette",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.octal.lisette",
          "match": "\\b0o[0-7_]+\\b"
        },
        {
          "name": "constant.numeric.binary.lisette",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.float.lisette",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?\\b"
        },
        {
          "name": "constant.numeric.float.lisette",
          "match": "\\b[0-9][0-9_]*[eE][+-]?[0-9_]+\\b"
        },
        {
          "name": "constant.numeric.decimal.lisette",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "constant.language.boolean.lisette",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "keyword.control.lisette",
          "match": "\\b(if|else|match|while|for|return|break|continue|loop|in)\\b"
        },
        {
          "name": "storage.type.lisette",
          "match": "\\b(fn|struct|enum|interface|impl|type|const|var)\\b"
        },
        {
          "name": "storage.modifier.lisette",
          "match": "\\b(pub)\\b"
        },
        {
          "name": "keyword.other.lisette",
          "match": "\\b(let|mut|import|defer|task|select|try|recover)\\b"
        },
        {
          "name": "keyword.operator.as.lisette",
          "match": "\\b(as)\\b"
        },
        {
          "name": "variable.language.wildcard.lisette",
          "match": "\\b_\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.lisette",
          "match": "\\b(int|int8|int16|int32|int64|uint|uint8|uint16|uint32|uint64|float32|float64|complex64|complex128|string|bool|rune|byte|error|uintptr|Never)\\b"
        },
        {
          "name": "support.function.builtin.lisette",
          "match": "\\b(panic|assert_type)\\b"
        },
        {
          "name": "constant.language.lisette",
          "match": "\\b(Some|None|Ok|Err)\\b"
        },
        {
          "name": "entity.name.type.lisette",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "function-definitions": {
      "patterns": [
        {
          "comment": "Function definition: fn name( or fn name<",
          "match": "\\b(fn)\\s+([a-z_][a-zA-Z0-9_]*)\\s*(?=[<(])",
          "captures": {
            "1": { "name": "storage.type.lisette" },
            "2": { "name": "entity.name.function.lisette" }
          }
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "comment": "Function call: name(",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.lisette" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.lisette",
          "match": "->|=>|\\|>"
        },
        {
          "name": "keyword.operator.range.lisette",
          "match": "\\.\\.=|\\.\\.(?!\\.)"
        },
        {
          "name": "keyword.operator.comparison.lisette",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.lisette",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.assignment.lisette",
          "match": "\\+=|-=|\\*=|/=|%=|="
        },
        {
          "name": "keyword.operator.arithmetic.lisette",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.reference.lisette",
          "match": "&"
        },
        {
          "name": "punctuation.separator.pipe.lisette",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.propagation.lisette",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.not.lisette",
          "match": "!"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.dot.lisette",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.comma.lisette",
          "match": ","
        },
        {
          "name": "punctuation.separator.semicolon.lisette",
          "match": ";"
        },
        {
          "name": "punctuation.separator.colon.lisette",
          "match": ":"
        }
      ]
    }
  }
}
