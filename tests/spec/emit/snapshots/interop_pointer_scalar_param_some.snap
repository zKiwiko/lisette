package main

import (
	"example.com/cfg"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	opt_1 := lisette.MakeOptionSome("custom")
	var ptr_2 *string
	if opt_1.Tag == lisette.OptionSome {
		ptr_2 = &opt_1.SomeVal
	}
	cfg.Configure(ptr_2)
}
