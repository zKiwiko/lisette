---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nimport \"go:strconv\"\n\nfn parse(s: string) -> Result<int, error> {\n  strconv.Atoi(s)\n}\n\nfn process() -> Result<int, error> {\n  let x = 42\n  let x = parse(f\"{x}\")?\n  Ok(x + 1)\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func parse(s string) (int, error) {
	return strconv.Atoi(s)
}

func process() (int, error) {
	x := 42
	ret_2, ret_3 := parse(fmt.Sprint(x))
	var check_5 lisette.Result[int, error]
	if ret_3 != nil {
		check_5 = lisette.MakeResultErr[int, error](ret_3)
	} else {
		check_5 = lisette.MakeResultOk[int, error](ret_2)
	}
	if check_5.Tag != lisette.ResultOk {
		return *new(int), check_5.ErrVal
	}
	x_1 := check_5.OkVal
	return x_1 + 1, nil
}
