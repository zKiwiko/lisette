---
source: tests/spec/emit/types.rs
description: "input: \nimport \"go:fmt\"\n\ntype MyInt = int\ntype MyString = string\n\nenum Either<L, R> {\n  Left(L),\n  Right(R),\n}\n\nimpl Either<MyInt, MyString> {\n  fn describe(self) -> MyString {\n    match self {\n      Either.Left(n) => fmt.Sprintf(\"int(%d)\", n),\n      Either.Right(s) => fmt.Sprintf(\"str(%s)\", s),\n    }\n  }\n}\n\nfn test() -> MyString {\n  let e: Either<MyInt, MyString> = Either.Left(42)\n  e.describe()\n}\n"
---
package main

import "fmt"

func MakeEitherLeft[L any, R any](arg0 L) Either[L, R] {
	return Either[L, R]{Tag: EitherLeft, Left: arg0}
}

func MakeEitherRight[L any, R any](arg0 R) Either[L, R] {
	return Either[L, R]{Tag: EitherRight, Right: arg0}
}

type MyInt = int

type MyString = string

type EitherTag int

const (
	EitherLeft EitherTag = iota
	EitherRight
)

type Either[L any, R any] struct {
	Tag   EitherTag
	Left  L
	Right R
}

func (e Either[L, R]) String() string {
	switch e.Tag {
	case EitherLeft:
		return fmt.Sprintf("Either.Left(%v)", e.Left)
	case EitherRight:
		return fmt.Sprintf("Either.Right(%v)", e.Right)
	default:
		return fmt.Sprintf("Either(%d)", e.Tag)
	}
}

func Either_describe(self Either[MyInt, MyString]) MyString {
	if self.Tag == EitherLeft {
		n := self.Left
		return fmt.Sprintf("int(%d)", n)
	}
	s := self.Right
	return fmt.Sprintf("str(%s)", s)
}

func test() MyString {
	e := MakeEitherLeft[int, MyString](42)
	return Either_describe(e)
}
