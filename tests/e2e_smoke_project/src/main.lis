      MethodEnum.Val(x) => x,
      MethodEnum.Empty => 0,
    }
  }

  fn doubled(self) -> int {
    self.get_val() * 2
  }
}

fn test_enum_method() -> int {
  let e = MethodEnum.Val(21)
  e.get_val()
}

fn test_enum_method_chained() -> int {
  let e = MethodEnum.Val(25)
  e.doubled()
}

