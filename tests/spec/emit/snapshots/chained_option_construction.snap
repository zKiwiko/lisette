---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn get_value() -> Option<int> {\n  Some(42)\n}\n\nfn test() -> Option<int> {\n  let x = get_value();\n  x\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func get_value() (int, bool) {
	return 42, true
}

func test() (int, bool) {
	option_1 := lisette.OptionFromCommaOk[int](get_value())
	x := option_1
	v_2 := x
	if v_2.Tag == lisette.OptionSome {
		return v_2.SomeVal, true
	}
	return *new(int), false
}
