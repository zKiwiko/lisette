---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn maybe_get() -> Option<int> {\n  None\n}\n\nfn process() -> Option<int> {\n  let x = maybe_get()?;\n  Some(x + 1)\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func maybe_get() (int, bool) {
	return *new(int), false
}

func process() (int, bool) {
	option_1 := lisette.OptionFromCommaOk[int](maybe_get())
	check_2 := option_1
	if check_2.Tag != lisette.OptionSome {
		return *new(int), false
	}
	x := check_2.SomeVal
	return x + 1, true
}
