// === main.go ===
package main

import (
	"fmt"
	"strconv"
)

func parse_int(s string) (int, error) {
	return strconv.Atoi(s)
}

func main() {
	ret_1, ret_2 := parse_int("42")
	if ret_2 == nil {
		n := ret_1
		fmt.Println(n)
	} else {
		e := ret_2
		fmt.Println(e)
	}
}
