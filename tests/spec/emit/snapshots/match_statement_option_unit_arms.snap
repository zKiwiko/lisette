---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn noop() {}\n\nfn maybe(b: bool) -> Option<int> {\n  if b { Some(42) } else { None }\n}\n\nfn test() {\n  match maybe(true) {\n    Some(_) => noop(),\n    None => noop(),\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func noop() {}

func maybe(b bool) (int, bool) {
	if b {
		return 42, true
	}
	return *new(int), false
}

func test() {
	option_2 := lisette.OptionFromCommaOk[int](maybe(true))
	subject_1 := option_2
	if subject_1.Tag == lisette.OptionSome {
		noop()
	} else {
		noop()
	}
}
