---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:strconv\"\n\nfn fallback(s: string) -> Result<int, error> { Ok(0) }\n\nfn main() {\n  let mut f = fallback\n  f = strconv.Atoi\n  let r = f(\"42\")\n  match r {\n    Ok(v) => { let _ = v },\n    Err(_) => { let _ = 0 },\n  }\n}\n"
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func fallback(_ string) (int, error) {
	return 0, nil
}

func main() {
	f := fallback
	f = strconv.Atoi
	ret_1, ret_2 := f("42")
	var r lisette.Result[int, error]
	if ret_2 != nil {
		r = lisette.MakeResultErr[int, error](ret_2)
	} else {
		r = lisette.MakeResultOk[int, error](ret_1)
	}
	if r.Tag == lisette.ResultOk {
		_ = r.OkVal
	} else {
		_ = 0
	}
}
