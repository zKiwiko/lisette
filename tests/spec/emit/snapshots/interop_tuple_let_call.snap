package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"path"
)

func main() {
	f := path.Split
	ret_1, ret_2 := f("/foo/bar.txt")
	tup_3 := lisette.MakeTuple2(ret_1, ret_2)
	_ = tup_3
}
