source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:flag\"\n\nfn make_lookup() -> fn(string) -> Option<Ref<flag.Flag>> {\n  flag.Lookup\n}\n\nfn main() {\n  let f = make_lookup()\n  let r = f(\"verbose\")\n  match r {\n    Some(v) => { let _ = v },\n    None => {},\n  }\n}\n"
---
package main

import (
	"flag"
	lisette "github.com/ivov/lisette/prelude"
)

func make_lookup() func(string) *flag.Flag {
	return flag.Lookup
}

func main() {
	f := make_lookup()
	raw_1 := f("verbose")
	option_2 := lisette.OptionFromNilable[*flag.Flag](raw_1, raw_1 == nil)
	r := option_2
	if r.Tag == lisette.OptionSome {
		_ = r.SomeVal
	}
}
