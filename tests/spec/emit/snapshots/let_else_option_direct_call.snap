---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn get_value(s: string) -> Option<int> {\n  if s == \"ok\" { Some(42) } else { None }\n}\n\nfn test() -> int {\n  let Some(x) = get_value(\"ok\") else { return 0; };\n  x\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func get_value(s string) (int, bool) {
	if s == "ok" {
		return 42, true
	}
	return *new(int), false
}

func test() int {
	option_2 := lisette.OptionFromCommaOk[int](get_value("ok"))
	subject_1 := option_2
	if subject_1.Tag != lisette.OptionSome {
		return 0
	}
	return subject_1.SomeVal
}
