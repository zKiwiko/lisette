---
source: tests/spec/emit/patterns.rs
description: "input: \nimport \"go:example.com/events\"\n\nfn handle(e: events.Event) -> int {\n  match e {\n    events.KeyPress { .. } | events.KeyRelease { .. } => 1,\n    _ => 0,\n  }\n}\n"
---
package main

import "example.com/events"

func handle(e events.Event) int {
	switch e.(type) {
	case events.KeyPress, events.KeyRelease:
		return 1
	default:
		return 0
	}
}
