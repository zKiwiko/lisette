package main

import "example.com/mixed"

type Svc struct{}

func (s Svc) String() string {
	return "Svc"
}

func (s Svc) Load(_ string) (int, error) {
	return 1, nil
}

func (s Svc) Name() string {
	return "svc"
}

func run(s mixed.Service) string {
	return s.Name()
}

func main() {
	s := Svc{}
	_ = run(s)
}
