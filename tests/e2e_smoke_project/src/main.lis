// Result/Option direct argument passing

fn divide_for_test(a: int, b: int) -> Result<int, string> {
  if b == 0 { Err("division by zero") } else { Ok(a / b) }
}

fn describe_result(r: Result<int, string>) -> string {
  match r {
    Ok(v) => f"{v}",
    Err(e) => e,
  }
}

fn maybe_int_for_test(b: bool) -> Option<int> {
  if b { Some(42) } else { None }
}

fn unwrap_or_for_test(o: Option<int>, fallback: int) -> int {
  match o {
    Some(v) => v,
    None => fallback,
  }
}

fn test_result_direct_arg_ok() -> int {
  let s = describe_result(divide_for_test(10, 2))
  if s == "5" { 100 } else { 0 }
}

fn test_result_direct_arg_err() -> int {
  let s = describe_result(divide_for_test(10, 0))
  if s == "division by zero" { 100 } else { 0 }
}

fn test_option_direct_arg_some() -> int {
  let v = unwrap_or_for_test(maybe_int_for_test(true), 0)
  if v == 42 { 100 } else { 0 }
}

fn test_option_direct_arg_none() -> int {
  let v = unwrap_or_for_test(maybe_int_for_test(false), 99)
  if v == 99 { 100 } else { 0 }
}

// Match in statement position with Unit arms
// These tests verify that match expressions with Unit-returning arms compile correctly
// The original bug generated invalid Go: `result_3 = fmt.Print(...)` and `return result_3`

fn noop() {}

fn test_match_statement_result() -> int {
  // This match is used as a statement (not assigned, not returned)
  // Arms call noop() which returns Unit - this triggered invalid Go code
  match divide_for_test(10, 2) {
    Ok(_) => noop(),
    Err(_) => noop(),
  }
  100 // If we get here, the code compiled correctly
}

fn test_match_statement_option() -> int {
  match maybe_int_for_test(true) {
    Some(_) => noop(),
    None => noop(),
  }
  100
}

fn parse_digit(s: string) -> Result<int, string> {
  if s == "0" {
    Ok(0)
  } else if s == "1" {
    Ok(1)
  } else if s == "2" { Ok(2) } else { Err("not a digit") }
}

fn test_result_if_else_chain_ok() -> int {
  let res = parse_digit("1")
  match res {
    Ok(n) => n,
    Err(_) => -1,
  }
}

fn test_result_if_else_chain_err() -> int {
  let res = parse_digit("x")
  match res {
    Ok(_) => -1,
    Err(_) => 100,
  }
}

fn get_optional(flag: bool) -> Option<int> {
  if flag { Some(42) } else { None }
}

fn test_option_if_else_chain_some() -> int {
  let opt = get_optional(true)
  match opt {
    Some(n) => n,
    None => -1,
  }
}

fn test_option_if_else_chain_none() -> int {
  let opt = get_optional(false)
  match opt {
    Some(_) => -1,
    None => 100,
  }
}

fn maybe_number(s: string) -> Option<int> {
  if s == "one" { Some(1) } else { None }
}

fn parse_number(s: string) -> Result<int, string> {
  if s == "42" { Ok(42) } else { Err("not 42") }
}

fn test_let_else_option_direct_call() -> int {
  let Some(num) = maybe_number("one") else {
    return 0
  }
  num
}

fn test_let_else_option_direct_call_else() -> int {
  let Some(_) = maybe_number("nope") else {
    return 100
  }
  0
}

fn test_let_else_result_direct_call() -> int {
  let Ok(num) = parse_number("42") else {
    return 0
  }
  if num == 42 { 100 } else { 0 }
}

fn test_let_else_result_direct_call_else() -> int {
  let Ok(_) = parse_number("abc") else {
    return 100
  }
  0
}

fn test_underscore_prefix_binding() -> int {
  let opt: Option<int> = Some(42)
  match opt {
    Some(_x) => 100,
    None => 0,
  }
}

fn test_underscore_prefix_binding_result() -> int {
  let res = Ok(42)
  match res {
    Ok(_val) => 100,
    Err(_msg) => 0,
  }
}

fn test_underscore_prefix_slice_rest() -> int {
  let items = [1, 2, 3, 4, 5]
  match items {
    [first, .._rest] => first,
    _ => 0,
  }
}

// numeric type alias operations

fn test_duration_times_literal() -> int {
  // Duration * literal - should not need cast
  let d = time.Duration.Second * 5
  if d == 5000000000 { 100 } else { 0 }
}

fn test_duration_times_variable() -> int {
  // Duration * variable - variable needs cast
  let n: int = 3
  let d = time.Duration.Second * n
  if d == 3000000000 { 100 } else { 0 }
}

fn test_duration_div_duration() -> int {
  // Duration / Duration - yields underlying type (ratio)
  let ratio: int64 = time.Duration.Second / time.Duration.Millisecond
  if ratio == 1000 { 100 } else { 0 }
}

fn test_duration_div_scalar() -> int {
  // Duration / scalar - yields Duration
  let half = time.Duration.Second / 2
  if half == 500000000 { 100 } else { 0 }
}

fn test_duration_add() -> int {
  // Duration + Duration
  let sum = time.Duration.Second + time.Duration.Millisecond
  if sum == 1001000000 { 100 } else { 0 }
}

fn test_duration_sub() -> int {
  // Duration - Duration
  let diff = time.Duration.Second - time.Duration.Millisecond
  if diff == 999000000 { 100 } else { 0 }
}

fn test_duration_comparison() -> int {
  // Duration > scalar
  if time.Duration.Second > 1000 { 100 } else { 0 }
}

fn test_duration_negation() -> int {
  // -Duration
  let neg = -time.Duration.Second
  if neg == -1000000000 { 100 } else { 0 }
}

fn test_eq_with_variable() -> int {
  let n: int = 1000000000
  if time.Duration.Second == n { 100 } else { 0 }
}

fn test_variable_not_variant() -> int {
  let n: int = 5
  let result: time.Duration = time.Duration.Second * n
  if result == 5000000000 { 100 } else { 0 }
}

// Regression test: negated literals with aliased types should not emit unnecessary casts
fn test_negated_literal_times_aliased() -> int {
  // -5 * Duration should emit as `-5 * time.Second`, NOT `time.Duration(-5) * time.Second`
  let d: time.Duration = -5 * time.Duration.Second
  if d == -5000000000 { 100 } else { 0 }
}

fn test_paren_negated_literal_times_aliased() -> int {
  // (-5) * Duration should emit as `(-5) * time.Second`, NOT `time.Duration((-5)) * time.Second`
  let d: time.Duration = (-5) * time.Duration.Second
  if d == -5000000000 { 100 } else { 0 }
}

// Go-style value enum access (time.Second)

fn test_go_style_access() -> int {
  // Go-style: time.Second (not time.Duration.Second)
  let d = time.Second
  if d == 1000000000 { 100 } else { 0 }
}

fn test_go_style_times_literal() -> int {
