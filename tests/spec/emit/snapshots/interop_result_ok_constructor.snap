---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:strconv\"\n\nfn make() -> Result<fn(string) -> Result<int, error>, error> {\n  Ok(strconv.Atoi)\n}\n\nfn main() {\n  let r = make()\n  match r {\n    Ok(f) => {\n      let r2 = f(\"1\")\n      match r2 {\n        Ok(v) => { let _ = v },\n        Err(_) => { let _ = 0 },\n      }\n    },\n    Err(_) => { let _ = 0 },\n  }\n}\n"
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func make_() (func(string) (int, error), error) {
	return strconv.Atoi, nil
}

func main() {
	ret_1, ret_2 := make_()
	var r lisette.Result[func(string) (int, error), error]
	if ret_2 != nil {
		r = lisette.MakeResultErr[func(string) (int, error), error](ret_2)
	} else {
		r = lisette.MakeResultOk[func(string) (int, error), error](ret_1)
	}
	if r.Tag == lisette.ResultOk {
		f := r.OkVal
		ret_4, ret_5 := f("1")
		var result_6 lisette.Result[int, error]
		if ret_5 != nil {
			result_6 = lisette.MakeResultErr[int, error](ret_5)
		} else {
			result_6 = lisette.MakeResultOk[int, error](ret_4)
		}
		r2 := result_6
		if r2.Tag == lisette.ResultOk {
			_ = r2.OkVal
		} else {
			_ = 0
		}
	} else {
		_ = 0
	}
}
