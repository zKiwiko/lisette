---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:fmt\"\n\nstruct Counter {\n  count: int,\n}\n\nimpl Counter {\n  fn String(self) -> string {\n    f\"{self.count}\"\n  }\n}\n\nfn make_pair(c: Counter) -> (fmt.Stringer, int) {\n  (c, c.count)\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

type Counter struct {
	count int
}

func (c Counter) String() string {
	return fmt.Sprintf("Counter { count: %v }", c.count)
}

func (c Counter) String() string {
	return fmt.Sprint(c.count)
}

func make_pair(c Counter) lisette.Tuple2[fmt.Stringer, int] {
	return lisette.MakeTuple2[fmt.Stringer, int](c, c.count)
}
