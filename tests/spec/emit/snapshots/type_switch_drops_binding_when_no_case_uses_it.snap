---
source: tests/spec/emit/patterns.rs
description: "input: \nimport \"go:example.com/events\"\n\nfn handle(e: events.Event) -> int {\n  match e {\n    events.Click { .. } => 1,\n    events.KeyPress { .. } => 2,\n    _ => 0,\n  }\n}\n"
---
package main

import "example.com/events"

func handle(e events.Event) int {
	switch e.(type) {
	case events.Click:
		return 1
	case events.KeyPress:
		return 2
	default:
		return 0
	}
}
