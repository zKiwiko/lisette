description: "input: \nimport \"go:strconv\"\n\nfn main() {\n  let ch = Channel.new<fn(string) -> Result<int, error>>()\n  select {\n    ch.send(strconv.Atoi) => { let _ = 0 },\n    _ => { let _ = 1 },\n  }\n}\n"
---
package main

import "strconv"

func main() {
	ch := make(chan func(string) (int, error))
	select {
	case ch <- strconv.Atoi:
		_ = 0
	default:
		_ = 1
	}
}
