---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:strconv\"\n\nstruct Holder { f: fn(string) -> Result<int, error> }\n\nfn main() {\n  let mut m = Map.new<string, Holder>()\n  m[\"a\"] = Holder { f: strconv.Atoi }\n  let mut entry = m[\"a\"]\n  entry.f = strconv.Atoi\n  m[\"a\"] = entry\n  let r = m[\"a\"].f(\"1\")\n  match r {\n    Ok(v) => { let _ = v },\n    Err(_) => { let _ = 0 },\n  }\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

type Holder struct {
	f func(string) (int, error)
}

func (h Holder) String() string {
	return fmt.Sprintf("Holder { f: %p }", h.f)
}

func main() {
	m := make(map[string]Holder)
	m["a"] = Holder{f: strconv.Atoi}
	entry := m["a"]
	entry.f = strconv.Atoi
	m["a"] = entry
	ret_1, ret_2 := m["a"].f("1")
	var r lisette.Result[int, error]
	if ret_2 != nil {
		r = lisette.MakeResultErr[int, error](ret_2)
	} else {
		r = lisette.MakeResultOk[int, error](ret_1)
	}
	if r.Tag == lisette.ResultOk {
		_ = r.OkVal
	} else {
		_ = 0
	}
}
