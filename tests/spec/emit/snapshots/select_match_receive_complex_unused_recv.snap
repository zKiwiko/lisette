---
source: tests/spec/emit/concurrency.rs
description: "input: \nstruct P { v: int }\nfn test() {\n  let ch = Channel.buffered<P>(1)\n  ch.send(P { v: 1 })\n  select {\n    match ch.receive() {\n      Some(P { v }) => (),\n      None => (),\n    },\n    _ => (),\n  }\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

type P struct {
	v int
}

func (p P) String() string {
	return fmt.Sprintf("P { v: %v }", p.v)
}

func test() {
	ch := make(chan P, 1)
	_ = lisette.ChannelSend(ch, P{v: 1})
	select {
	case recv_1, ok := <-ch:
		_ = ok
		_ = recv_1
	default:
	}
}
