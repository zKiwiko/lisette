---
source: tests/spec/emit/patterns.rs
description: "input: \nimport \"go:example.com/events\"\n\nfn handle(e: events.Event, active: bool) -> int {\n  match e {\n    events.Click { .. } | events.Scroll { .. } if active => 1,\n    _ => 0,\n  }\n}\n"
---
package main

import "example.com/events"

func handle(e events.Event, active bool) int {
	switch e.(type) {
	case events.Click, events.Scroll:
		if active {
			return 1
		}
		return 0
	default:
		return 0
	}
}
