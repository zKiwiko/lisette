---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"slices"
)

type Prefix = lisette.Range[int]

func test(arr []int, r Prefix) []int {
	owned := slices.Clone(arr[r.Start:r.End:r.End])
	owned[0] = 99
	return owned
}
