---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn maybe_int(x: int) -> Option<int> {\n  if x > 0 { Some(x) } else { None }\n}\n\nfn maybe_string(s: string) -> Option<string> {\n  if s != \"\" { Some(s) } else { None }\n}\n\nfn test() {\n  let pair = (maybe_int(5), maybe_string(\"hello\"));\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func maybe_int(x int) (int, bool) {
	if x > 0 {
		return x, true
	}
	return *new(int), false
}

func maybe_string(s string) (string, bool) {
	if s != "" {
		return s, true
	}
	return *new(string), false
}

func test() {
	option_1 := lisette.OptionFromCommaOk[int](maybe_int(5))
	option_2 := lisette.OptionFromCommaOk[string](maybe_string("hello"))
	_ = lisette.MakeTuple2(option_1, option_2)
}
