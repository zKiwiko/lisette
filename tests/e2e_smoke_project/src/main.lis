  let f = Fallible { value: 25 }
  match f.get() {
    Ok(n) => n,
    Err(_) => -1,
  }
}

fn try_return_helper() -> Result<int, string> {
  let v = fallible()?
  Ok(v + 5)
}

fn test_try_in_return() -> int {
  match try_return_helper() {
    Ok(n) => n,
    Err(_) => -1,
  }
}

fn test_try_in_lambda() -> int {
  let f = |x: int| -> Result<int, string> {
    let v = fallible()?
    Ok(v + x)
  }
  match f(5) {
    Ok(n) => n,
    Err(_) => -1,
  }
}

