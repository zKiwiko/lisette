---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:fmt\"\n\nstruct Counter {\n  count: int,\n}\n\nimpl Counter {\n  fn String(self) -> string {\n    f\"{self.count}\"\n  }\n}\n\nfn make_pair(c: Counter, positive: bool) -> (fmt.Stringer, int) {\n  if positive {\n    return (Counter { count: c.count + 1 }, c.count)\n  }\n  (c, c.count)\n}\n"
---
package main

import "fmt"

type Counter struct {
	count int
}

func (c Counter) GoString() string {
	return fmt.Sprintf("Counter { count: %v }", c.count)
}

func (c Counter) String() string {
	return fmt.Sprint(c.count)
}

func make_pair(c Counter, positive bool) (fmt.Stringer, int) {
	if positive {
		return Counter{count: c.count + 1}, c.count
	}
	return c, c.count
}
