---
source: tests/spec/emit/expressions.rs
description: "input: \nimport \"go:fmt\"\n\nfn make_range() -> Range<int> {\n  fmt.Println(\"range\")\n  1..3\n}\n\nfn main() {\n  let items = [0, 1, 2, 3, 4]\n  let sub = items[make_range()]\n  fmt.Println(sub.length())\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func make_range() lisette.Range[int] {
	fmt.Println("range")
	return lisette.Range[int]{
		Start: 1,
		End:   3,
	}
}

func main() {
	items := []int{0, 1, 2, 3, 4}
	_base_2 := items
	range_1 := make_range()
	sub := _base_2[range_1.Start:range_1.End:range_1.End]
	fmt.Println(len(sub))
}
