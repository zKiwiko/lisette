---
source: tests/spec/emit/partial.rs
description: "input: \nfn test(p: Partial<int, string>) -> int {\n  match p {\n    Partial.Ok(n) => n,\n    Partial.Err(_) => 0,\n    Partial.Both(n, _) => n,\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(p lisette.Partial[int, string]) int {
	switch p.Tag {
	case lisette.PartialOk:
		n := p.OkVal
		return n
	case lisette.PartialErr:
		return 0
	default:
		n := p.OkVal
		return n
	}
}
