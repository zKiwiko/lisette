---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn test() -> Option<int> {\n  try {\n    let _ = Some(1)?;\n    panic(\"fatal\")\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() (int, bool) {
	tryResult_1 := func() lisette.Option[int] {
		check_2 := lisette.MakeOptionSome(1)
		if check_2.Tag != lisette.OptionSome {
			return lisette.MakeOptionNone[int]()
		}
		panic("fatal")
	}()
	v_3 := tryResult_1
	if v_3.Tag == lisette.OptionSome {
		return v_3.SomeVal, true
	}
	return *new(int), false
}
