---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:path\"\n\nfn use_split(f: fn(string) -> (string, string), p: string) -> string {\n  let (dir, file) = f(p)\n  f\"{dir}/{file}\"\n}\n\nfn main() {\n  let r = use_split(path.Split, \"/foo/bar.txt\")\n  let _ = r\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"path"
)

func use_split(f func(string) (string, string), p string) string {
	ret_2, ret_3 := f(p)
	tup_4 := lisette.MakeTuple2(ret_2, ret_3)
	tmp_1 := tup_4
	dir := tmp_1.First
	file := tmp_1.Second
	return fmt.Sprintf("%v/%v", dir, file)
}

func main() {
	_ = use_split(path.Split, "/foo/bar.txt")
}
