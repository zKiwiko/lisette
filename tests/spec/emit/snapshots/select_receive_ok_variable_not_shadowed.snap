---
source: tests/spec/emit/concurrency.rs
description: "input: \nimport \"go:fmt\"\n\nfn test() {\n  let ok = \"everything is fine\"\n  let ch = Channel.buffered<int>(1)\n  ch.send(42)\n  select {\n    match ch.receive() {\n      Some(val) => {\n        fmt.Println(f\"received: {val}\")\n        fmt.Println(f\"ok is: {ok}\")\n      },\n      None => fmt.Println(\"closed\"),\n    },\n  }\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func test() {
	ok := "everything is fine"
	ch := make(chan int, 1)
	_ = lisette.ChannelSend(ch, 42)
	select {
	case val, ok_1 := <-ch:
		if ok_1 {
			fmt.Printf("received: %v\n", val)
			fmt.Printf("ok is: %v\n", ok)
		} else {
			fmt.Println("closed")
		}
	}
}
