// === main.go ===
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"strings"
)

func main() {
	ret_1, ret_2, ret_3 := strings.Cut("hello-world", "-")
	tup_4 := lisette.MakeTuple3(ret_1, ret_2, ret_3)
	result := tup_4
	fmt.Println(result)
}
