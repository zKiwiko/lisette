package main

func main() {
	s := "ab"
	count := 0
	_s_1 := s
	for _i_2 := 0; _i_2 < len(_s_1); _i_2++ {
		b := _s_1[_i_2]
		count++
		s = ""
		_ = b
	}
	if count != 2 {
		panic("expected count 2 — bytes loop must iterate over the original string")
	}
}
