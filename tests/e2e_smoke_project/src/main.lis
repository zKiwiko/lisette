    Err(_) => 0,
  }
}

fn test_result_map_or() -> int {
  let res: Result<int, string> = Err("error")
  let result = res.map_or(100, |x| x * 2)
  result
}

// Non-UFCS to UFCS method chaining (filter returns Option, then map is UFCS)
fn test_option_filter_then_map() -> int {
  let opt = Some(10)
  let result = opt.filter(|x| x > 5).map(|y| y * 2)
  match result {
    Some(v) => if v == 20 { 100 } else { 0 },
    None => 0,
  }
}

// Non-UFCS to UFCS method chaining (or_else returns Option, then map is UFCS)
fn test_option_or_else_then_map() -> int {
  let opt: Option<int> = None
  let result = opt.or_else(|| Some(50)).map(|x| x * 2)
  match result {
    Some(v) => if v == 100 { 100 } else { 0 },
    None => 0,
  }
}

// Non-UFCS to non-UFCS method chaining (filter returns Option, then is_some)
fn test_option_filter_then_is_some() -> int {
  let opt = Some(10)
  let result = opt.filter(|x| x > 5).is_some()
  if result { 100 } else { 0 }
}

// Result ok (non-UFCS returning Option) chained into map (UFCS)
fn test_result_ok_then_map() -> int {
  let res = Ok(25)
  let result = res.ok().map(|x| x * 4)
  match result {
    Some(v) => if v == 100 { 100 } else { 0 },
    None => 0,
  }
}

// Closure body returns UFCS call (nested UFCS in and_then callback)
fn test_nested_ufcs_in_and_then() -> int {
  let opt = Some(10)
  let result = opt.and_then(|x| Some(x).map(|y| y * 2))
  match result {
    Some(v) => if v == 20 { 100 } else { 0 },
    None => 0,
  }
}

// Triple chain: non-UFCS -> UFCS -> UFCS
fn test_triple_chain_filter_map_map() -> int {
  let opt = Some(10)
  let result = opt.filter(|x| x > 5).map(|y| y * 2).map(|z| z + 1)
  match result {
    Some(v) => if v == 21 { 100 } else { 0 },
    None => 0,
  }
}

// Result and_then with closure returning Ok
fn test_result_and_then_ok() -> int {
  let res = Ok(10)
  let result = res.and_then(|x| Ok(x * 3))
  match result {
    Ok(v) => if v == 30 { 100 } else { 0 },
    Err(_) => 0,
  }
}

// Result and_then with closure returning Err
fn test_result_and_then_err() -> int {
  let res = Ok(10)
  let result = res.and_then(|_| Err("failed"))
  match result {
    Ok(_) => 0,
    Err(e) => if e == "failed" { 100 } else { 0 },
  }
}

// Result or_else with closure returning Ok (recovery)
fn test_result_or_else_recover() -> int {
  let res: Result<int, string> = Err("original")
  let result = res.or_else(|_| Ok(42))
  match result {
    Ok(v) => if v == 42 { 100 } else { 0 },
    Err(_) => 0,
  }
}

// Long UFCS chain
fn test_long_ufcs_chain() -> int {
  let opt = Some(1)
  let result = opt.map(|x| x + 1).map(|x| x * 2).map(|x| x + 3).map(|x| x * 2)
  match result {
    Some(v) => if v == 14 { 100 } else { 0 },
    None => 0,
  }
}

// Regression tests for closure/UFCS bugs

// Generic function accepting closure that returns Result
fn apply_result<T, U, E>(r: Result<T, E>, f: fn(T) -> Result<U, E>) -> Result<U, E> {
  r.and_then(f)
}

fn test_generic_fn_result_closure() -> int {
  let r = Ok(5)
  match apply_result(r, |x| Ok(x * 2)) {
    Ok(v) => if v == 10 { 100 } else { 0 },
    Err(_) => 0,
  }
}

// User-defined UFCS method returning Result
struct Transformer<T> { value: T }

impl<T> Transformer<T> {
  fn apply<U, E>(self, f: fn(T) -> Result<U, E>) -> Result<U, E> {
    f(self.value)
  }
}

fn test_user_ufcs_method_result() -> int {
  let t = Transformer { value: 10 }
  match t.apply(|x: int| -> Result<int, string> {
    Ok(x * 2)
  }) {
    Ok(v) => if v == 20 { 100 } else { 0 },
    Err(_) => 0,
  }
}

// Closure stored in variable with and_then chain
fn test_closure_var_and_then_chain() -> int {
  let make = |n: int| -> Result<int, string> {
    if n > 0 { Ok(n * 10) } else { Err("non-positive") }
  }
  match make(5).and_then(|x| make(x / 10)) {
    Ok(v) => if v == 50 { 100 } else { 0 },
    Err(_) => 0,
  }
}

// Mutual recursion with Result return
fn even_check(n: int) -> Result<bool, string> {
  if n < 0 {
    Err("negative")
  } else if n == 0 { Ok(true) } else { odd_check(n - 1) }
}

fn odd_check(n: int) -> Result<bool, string> {
  if n < 0 {
    Err("negative")
  } else if n == 0 { Ok(false) } else { even_check(n - 1) }
}

fn test_mutual_recursion_result() -> int {
  match (even_check(4), odd_check(5)) {
    (Ok(a), Ok(b)) => if a && b { 100 } else { 0 },
    _ => 0,
  }
}

// Go Result call wrapping tests
// Tests for Go functions returning (T, error) wrapped as Result<T, error>
fn test_go_result_call_let_underscore() -> int {
  // Discarding result with let _ = should work
  // fmt.Print returns (int, error) in Go, which is Result<int, error> in Lisette
  let _ = fmt.Print("")
  100
}

fn test_go_result_call_in_match() -> int {
  // Using Go result call in match should work
  match fmt.Print("") {
    Ok(_) => 100,
    Err(_) => 0,
  }
}

fn test_go_result_call_assigned() -> int {
  // Assigning Go result call to variable should work
  let result = fmt.Print("")
  match result {
    Ok(n) => if n == 0 { 100 } else { 0 },
    Err(_) => 0,
  }
}

// Recover block tests
fn panicking_function() -> int {
  // Trigger a panic via index out of bounds
  let arr: Slice<int> = []
  arr[0]
}

fn test_recover_catches_panic() -> int {
  let result = recover {
    panicking_function()
  }
  match result {
    Ok(_) => 0,
    Err(pv) => {
      // Just check we got a panic, message varies by Go version
      if pv.message().length() > 0 { 100 } else { 0 }
    },
  }
}

fn test_recover_success_path() -> int {
  let result = recover {
    42
  }
  match result {
    Ok(n) => if n == 42 { 100 } else { 0 },
    Err(_) => 0,
  }
}

fn test_recover_with_statements() -> int {
  let result = recover {
    let x = 10
    let y = 20
    x + y
  }
  match result {
    Ok(n) => if n == 30 { 100 } else { 0 },
    Err(_) => 0,
  }
}

fn test_recover_panic_value_stack_trace() -> int {
  let result = recover {
    panicking_function()
  }
  match result {
    Ok(_) => 0,
    Err(pv) => {
      let stack = pv.stack_trace()
      // Stack trace should contain something (not empty)
      if stack.length() > 0 { 100 } else { 0 }
    },
  }
}

fn test_recover_nested() -> int {
  let outer = recover {
    let inner = recover {
      panicking_function()
    }
    match inner {
      Ok(_) => 0,
      Err(_) => 50,
    } // Inner caught the panic
  }
  match outer {
    Ok(n) => if n == 50 { 100 } else { 0 },
    Err(_) => 0,
  } // Outer should not see panic
}

// as cast syntax

fn test_cast_int_to_float64() -> int {
  let x: int = 42
  let y: float64 = x as float64
  if y == 42.0 { 100 } else { 0 }
}

fn test_cast_float64_to_int() -> int {
  let x: float64 = 3.9
  let y: int = x as int
  if y == 3 {
    100
  } else {
    0 // truncates toward zero
  }
}

fn test_cast_int_to_rune() -> int {
  let x: int = 65
  let r: rune = x as rune
  if r == 'A' { 100 } else { 0 }
}

fn test_cast_rune_to_int() -> int {
  let r: rune = 'Z'
  let x: int = r as int
  if x == 90 { 100 } else { 0 }
}

fn test_cast_string_to_byte_slice() -> int {
  let s: string = "hello"
  let bytes: Slice<byte> = s as Slice<byte>
  if bytes.length() == 5 && (bytes[0] as int) == 104 {
    100
  } else {
    0 // 'h' = 104
  }
}

fn test_cast_byte_slice_to_string() -> int {
  let bytes: Slice<byte> = "world" as Slice<byte>
  let s: string = bytes as string
  if s == "world" { 100 } else { 0 }
}

fn test_cast_string_to_rune_slice() -> int {
  let s: string = "héllo"
  let runes: Slice<rune> = s as Slice<rune>
  if runes.length() == 5 && runes[1] == 'é' { 100 } else { 0 }
}

fn test_cast_rune_slice_to_string() -> int {
  let runes: Slice<rune> = ['h', 'i']
  let s: string = runes as string
  if s == "hi" { 100 } else { 0 }
}

fn test_cast_in_expression() -> int {
  let a: int = 7
  let b: int = 2
  let result: float64 = (a as float64) / (b as float64)
  if result == 3.5 { 100 } else { 0 }
}

fn test_cast_int_to_int8() -> int {
  let x: int = 127
  let y: int8 = x as int8
  if y == 127 { 100 } else { 0 }
}

fn test_cast_float32_to_float64() -> int {
  let x: float32 = 1.5
  let y: float64 = x as float64
  if y == 1.5 { 100 } else { 0 }
}

fn test_cast_duration_to_int64() -> int {
  // Enum with numeric underlying type should be castable
  let d: time.Duration = time.Second
  let nanos: int64 = d as int64
  if nanos == 1000000000 { 100 } else { 0 }
}

fn test_cast_int64_to_duration() -> int {
  // int64 should be castable to enum with int64 underlying
  let nanos: int64 = 5000000000
  let d: time.Duration = nanos as time.Duration
  if d == 5 * time.Second { 100 } else { 0 }
}

// Slice.fold and Slice.find

fn test_slice_fold_sum() -> int {
  let nums = [1, 2, 3, 4, 5]
  if nums.fold(0, |acc, x| acc + x) == 15 { 100 } else { 0 }
}

fn test_slice_fold_product() -> int {
  let nums = [1, 2, 3, 4, 5]
  if nums.fold(1, |acc, x| acc * x) == 120 { 100 } else { 0 }
}

fn test_slice_fold_empty() -> int {
  let empty: Slice<int> = []
  if empty.fold(42, |acc, x| acc + x) == 42 { 100 } else { 0 }
}

fn test_slice_find_some() -> int {
  let nums = [1, 2, 3, 4, 5]
  match nums.find(|x| x > 3) {
    Some(4) => 100,
    _ => 0,
  }
}

fn test_slice_find_none() -> int {
  let nums = [1, 2, 3, 4, 5]
  match nums.find(|x| x > 100) {
    None => 100,
    _ => 0,
  }
}

fn test_slice_find_empty() -> int {
  let empty: Slice<int> = []
  match empty.find(|x| x > 0) {
    None => 100,
    _ => 0,
  }
}

fn test_slice_enumerate() -> int {
  let items = [10, 20, 30]
  let mut sum = 0
  for (i, v) in items.enumerate() {
    sum = sum + i * 100 + v
  }
  // 0*100+10 + 1*100+20 + 2*100+30 = 10 + 120 + 230 = 360
  if sum == 360 { 100 } else { 0 }
}

fn test_enumerated_slice_filter() -> int {
  let items = [10, 20, 30, 40]
  let evens = items.enumerate().filter(|(i, _)| i % 2 == 0)
  // indices 0 and 2 pass: [(0, 10), (2, 30)]
  if evens.length() == 2 {
    let (i0, v0) = evens[0]
    let (i1, v1) = evens[1]
    if i0 == 0 && v0 == 10 && i1 == 2 && v1 == 30 { 100 } else { 0 }
  } else {
    0
  }
}

fn test_slice_join() -> int {
  let result = ["hello", "world"].join(", ")
  if result == "hello, world" { 100 } else { 0 }
}

enum ASTNode {
  Number(int),
  String(string),
  Null,
}

fn test_enum_variant_named_string() -> int {
  let n = ASTNode.String("hello")
  let num = ASTNode.Number(42)
  let null = ASTNode.Null
  let s_ok = match n {
    ASTNode.String(s) => s == "hello",
    _ => false,
  }
  let n_ok = match num {
    ASTNode.Number(v) => v == 42,
    _ => false,
  }
  let null_ok = match null {
    ASTNode.Null => true,
    _ => false,
  }
  if s_ok && n_ok && null_ok { 100 } else { 0 }
}

fn test_map_from() -> int {
  let m = Map.from([("a", 1), ("b", 2)])
  if m.length() == 2 {
    match m.get("a") {
      Some(1) => 100,
      _ => 0,
    }
  } else {
    0
  }
}

fn test_string_range_slicing() -> int {
  let s = "hello world"
  if s[0..5] == "hello" {
    if s[6..] == "world" { if s[..5] == "hello" { 100 } else { 0 } } else { 0 }
  } else {
    0
  }
}

// SUS-167: transitive import `tls.Client` (function) must not shadow `http.Client` (struct).
// `go:crypto/tls` also exports a function named `Client`; it must not shadow the struct.
fn test_go_import_not_shadowed_by_transitive() -> int {
  let c: Option<Ref<httpx.Client>> = None
  if c.is_none() { 100 } else { 0 }
}

fn serve(h: httpx.Handler) -> int {
  let rec = httptest.NewRecorder()
  let req = httptest.NewRequest("GET", "/", bytes.NewBufferString(""))
  h.ServeHTTP(rec, req)
  rec.Code
}

fn test_handlerfunc_conversion() -> int {
  let h = httpx.HandlerFunc(|w: httpx.ResponseWriter, _r: Ref<httpx.Request>| {
    w.WriteHeader(httpx.StatusNoContent)
  })
  if serve(h) == httpx.StatusNoContent { 100 } else { 0 }
}

// Pointer receiver on struct literal (value type) — needs `mut`
fn test_pointer_receiver_struct_literal() -> int {
  let mut wg = sync.WaitGroup {}
  wg.Add(1)
  wg.Done()
  wg.Wait()
  100
}

// Pointer receiver on constructor-returned Ref<T> — no `mut` needed
fn test_pointer_receiver_constructor() -> int {
  let buf = bytes.NewBufferString("hello")
  match buf.ReadString(111) {
    Ok(s) => if s == "hello" { 100 } else { 0 },
    Err(_) => 100,
  } // EOF is expected, but we still read "hello"
}

// Pointer receiver method expression
fn test_pointer_receiver_method_expr() -> int {
  let f = bytes.Buffer.WriteString
  let mut buf = bytes.Buffer {}
  match f(&buf, "hello") {
    Ok(n) => if n == 5 { 100 } else { 0 },
    Err(_) => 0,
  }
}

