// === main.go ===
package main

import (
	"context"
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"time"
)

func main() {
	ctx := context.Background()
	option_1 := lisette.OptionFromCommaOk[time.Time](ctx.Deadline())
	deadline := option_1
	fmt.Print(deadline.IsSome())
}
