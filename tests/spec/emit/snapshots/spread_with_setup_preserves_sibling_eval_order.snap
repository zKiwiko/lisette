package main

import lisette "github.com/ivov/lisette/prelude"

func side_a() int {
	return 1
}

func get_xs() ([]int, error) {
	return []int{1, 2, 3}, nil
}

func variadic(_ int, _ ...int) int {
	return 0
}

func run() (int, error) {
	_arg_6 := side_a()
	ret_1, ret_2 := get_xs()
	var check_4 lisette.Result[[]int, error]
	if ret_2 != nil {
		check_4 = lisette.MakeResultErr[[]int, error](ret_2)
	} else {
		check_4 = lisette.MakeResultOk[[]int, error](ret_1)
	}
	if check_4.Tag != lisette.ResultOk {
		return *new(int), check_4.ErrVal
	}
	result_5 := check_4.OkVal
	return variadic(_arg_6, result_5...), nil
}
